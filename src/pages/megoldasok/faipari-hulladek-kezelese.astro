---
// Nyitás-archetípus: tünet · Vezető pillér: Anyag-először + Függetlenség
import SolutionPage from '../../components/site/SolutionPage.astro';

const trust = [
  { value: '3 az 1-ben', label: 'darálás · elszívás · brikettálás' },
  { value: '6', label: 'európai gyártó, egy kézből' },
  { value: '1', label: 'felelős a teljes anyagútra' },
  { value: '2008', label: 'óta a faiparban' },
];

const situations = [
  { icon: 'wind', title: 'Mindennap visszatér a por és a forgács', text: 'A gépek körül folyamatosan gyűlik az anyag, és a műszak végén külön takarítani kell. Ez minden nap visszatérő munkaóra, amit másra is lehetne fordítani.' },
  { icon: 'maximize', title: 'Fogy a hely a laza anyagtól', text: 'A laza apríték és fahulladék gyorsan megtölti a konténert és a sarkokat. Előbb-utóbb a tárolóhely szab határt a termelésnek.' },
  { icon: 'shuffle', title: 'Vegyes a hulladék, nehéz vele bármit kezdeni', text: 'Darabos és apró egyszerre keletkezik, így ahogy van, sem hasznosítani, sem értékesíteni nem egyszerű. Előkészítés nélkül a teljes mennyiség hulladék marad.' },
  { icon: 'recycle', title: 'Kár érte fizetni az elszállításnál', text: 'Amiért most az elszállítás díját fizeti, abból egy kis előkészítéssel tüzelő vagy brikett is lehetne. A költséghely így bevételi oldallá fordítható.' },
  { icon: 'clock', title: 'Több idő megy a mozgatásra, mint kéne', text: 'A gyűjtés, az ürítés és a pakolás elviszi az emberek idejét a tényleges munka elől. Egy rendezett anyagút ezt a holtidőt csökkenti.' },
  { icon: 'shield', title: 'A felgyűlt anyag már biztonsági kérdés', text: 'Az útban álló, poros anyag balesetveszélyes, és egy hatósági ellenőrzésnél sem előnyös. A rendezett kezelés a munkavédelmi kockázatot is csökkenti.' },
];

const directions = [
  { icon: 'shuffle', name: 'Ipari darálás', line: 'Vegyes fahulladék aprítása; kezelhető, tárolható és továbbdolgozható alapanyag.', href: '/technologiak/ipari-daralas/' },
  { icon: 'wind', name: 'Elszívás és porleválasztás', line: 'A por és a forgács elszívása a keletkezés helyén; tisztább levegő, kevesebb takarítás.', href: '/technologiak/elszivas-porlevalasztas/' },
  { icon: 'flame', name: 'Brikettálás', line: 'A száraz mellékanyag briketté tömörítése; a költséghelyből eladható termék.', href: '/technologiak/brikettalas/' },
];

const faq = [
  { q: 'Honnan tudom, melyik technológia kell?', a: 'Az anyagból indulunk ki. Ha elmondja, mi keletkezik, mennyi és milyen nedvességgel, abból meghatározzuk, hogy darálás, elszívás, brikettálás vagy ezek kombinációja illik a folyamathoz. Nem kell előre eldöntenie.' },
  { q: 'Megoldható az egész egy beszállítótól?', a: 'Igen. Több vezető európai gyártó kínálatából egyetlen, összehangolt anyagutat állítunk össze, és egy felelőssel végig ott vagyunk a tervezéstől az üzembe helyezésig.' },
  { q: 'Mekkora mennyiségtől éri meg foglalkozni vele?', a: 'Ezt a konkrét anyag és a kezelési, elszállítási költség dönti el — nincs egységes küszöbszám. Az első lépés egy rövid helyzetfelmérés, amely megmutatja, hol térül meg az előkészítés.' },
];
---

<SolutionPage
  title="Faipari hulladék kezelése"
  description="Forgács, por, apríték és fahulladék rendezett kezelése: darálás, elszívás és brikettálás összehangolva, több gyártó kínálatából, egy felelőssel."
  heroLead="A faüzemben keletkező forgács, por, apríték és fahulladék kezelése összetett folyamat. A folyamat ismeretében látszik, hol éri meg aprítani, elszívni vagy brikettálni. Ott pedig hely, idő és megtakarítás szabadul fel."
  heroImage="/heroes/hero-faipari-hulladek.jpg"
  heroImageAlt="Négytengelyes ipari hulladékdaráló gépsor üzemi környezetben"
  source="megoldas-faipari-hulladek"
  situationsTitle="Mikor nem halasztható a fahulladék kezelése?"
  situationsLead="Az alábbi helyzetekben érdemes átgondolni a keletkező faüzemi hulladék sorsát."
  trust={trust}
  situations={situations}
  directionsLead="A faipari hulladék ritkán egyetlen géptől függ. A legtöbb üzemben a darálás, az elszívás és a brikettálás összehangolása vezet rendezett anyaghoz. Mindhárom irányt egy helyről, több vezető európai gyártó kínálatából állítjuk össze, így a megoldás a feladathoz igazodik, nem egyetlen márka katalógusához."
  directions={directions}
  faq={faq}
  ctaTitle="Beszéljük át a faipari hulladék útját"
  ctaLead="Mondja el, milyen anyag keletkezik az üzemében, mennyi és hová kerül most. Közösen meghatározzuk, hogy a darálás, az elszívás és a brikettálás milyen kombinációja illik a folyamataihoz, és mi térül meg a leggyorsabban."
/>
