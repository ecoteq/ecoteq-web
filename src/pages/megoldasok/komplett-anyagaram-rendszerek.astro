---
// Nyitás-archetípus: rendszer / döntési-villa · Vezető pillér: Végig ott vagyunk + Függetlenség
import SolutionPage from '../../components/site/SolutionPage.astro';

const situations = [
  { icon: 'layers', title: 'Több, egymásra épülő technológiai lépés', text: 'A feladat nem egyetlen géppel oldható meg: az anyag a fogadástól a végtermékig több lépésen halad át, amelyeket egymáshoz kell illeszteni.' },
  { icon: 'route', title: 'A gépek között akad meg az anyag útja', text: 'A fő gépek külön-külön működnek, de az adagolás, a kihordás és a továbbítás nincs összehangolva, ezért a folyamat egyenetlen.' },
  { icon: 'boxes', title: 'Fogadás, előkészítés és tárolás megoldatlan', text: 'A bejövő anyag fogadása, az előkészítés és a végtermék tárolása esetleges, így a fő technológia nem tud folyamatosan dolgozni.' },
  { icon: 'settings', title: 'Hiányzó közös vezérlés és összehangolás', text: 'A különálló gépek külön indulnak és állnak le. Egységes vezérlés nélkül nehéz kiegyensúlyozott üzemet tartani.' },
  { icon: 'factory', title: 'Bővítés vagy átalakítás egy meglévő üzemben', text: 'Új technológiai lépés vagy kapacitásbővítés esetén a meglévő gépeket, az anyagáramot és a teret együtt, rendszerként kell átgondolni.' },
  { icon: 'gauge', title: 'Egyenetlen kapacitás a lépések között', text: 'Ha az egyes gépek eltérő teljesítménnyel dolgoznak, megfelelő pufferelés és méretezés nélkül a leglassabb lépés fogja vissza az egész rendszert.' },
];

const directions = [
  { icon: 'shuffle', name: 'Ipari darálás', line: 'Bemenő anyag aprítása egyenletes, kezelhető frakcióra a további lépésekhez.', href: '/technologiak/ipari-daralas/' },
  { icon: 'thermometer', name: 'Biomassza-szárítás', line: 'Nedvességtartalom beállítása a tömörítés vagy a hasznosítás előtti előkészítéshez.', href: '/technologiak/biomassza-szaritas/' },
  { icon: 'flame', name: 'Brikettálás', line: 'Előkészített anyag tömörítése brikettbe a rendszer kihordási oldalán.', href: '/technologiak/brikettalas/' },
  { icon: 'package', name: 'Pelletálás', line: 'Előkészített anyag pelletté formálása egységes, tárolható végtermékként.', href: '/technologiak/pelletalas/' },
  { icon: 'wind', name: 'Elszívás és porleválasztás', line: 'A keletkező por és apró szemcse elszívása és leválasztása a folyamat mentén.', href: '/technologiak/elszivas-porlevalasztas/' },
  { icon: 'route', name: 'Anyagmozgatás és rendszerelemek', line: 'Adagolás, kihordás és továbbítás, amely a fő gépeket egy rendszerré köti össze.', href: '/technologiak/anyagmozgas-rendszerelemek/' },
];

const faq = [
  { q: 'Miért jobb rendszerként tervezni, mint gépenként vásárolni?', a: 'Mert a leglassabb vagy rosszul illesztett lépés fogja vissza az egész üzemet. Rendszerként a kapacitások összehangolhatók, és egy felelős visel gondot a teljes anyagáramért.' },
  { q: 'Egy meglévő üzemet is át lehet alakítani rendszerré?', a: 'Igen. A meglévő gépeket, az anyagáramot és a teret felmérjük, és a hiányzó láncszemeket illesztjük be, bővítés vagy átalakítás formájában.' },
  { q: 'Tényleg egy beszállító viszi az egészet?', a: 'Igen. Több vezető gyártó kínálatából állítjuk össze a rendszert, de a tervezéstől az üzembe helyezésig egy felelős koordinálja a folyamatot. [VALIDÁLANDÓ: referenciaprojekt megnevezése].' },
];
---

<SolutionPage
  title="Komplett anyagáram-rendszerek"
  description="Komplett anyagáram-rendszerek: az ECOTEQ rendszerként tervezi az anyag útját a fogadástól a végtermékig, összehangolt gépekkel, több gyártó kínálatából, egy felelőssel."
  heroLead="Egy működő üzemben az anyag útja a fogadástól a végtermékig több gépen halad át: fogadás, előkészítés, fő technológia, kihordás, tárolás és vezérlés. Ha ezek külön-külön jók, de nincsenek összehangolva, a leglassabb lépés fogja vissza az egészet. Az ECOTEQ nem önálló gépet, hanem rendszert tervez, amelyben a lépések együtt dolgoznak."
  heroImage="/heroes/hero-komplett.jpg"
  heroImageAlt="Faapríték- és fűrészpor-tároló és -szárító üzem alkonyatkor"
  source="megoldas-komplett-anyagaram"
  situationsTitle="Mikor beszélünk rendszerről?"
  situationsLead="Az alábbi helyzetekben éri meg az anyag útját rendszerként átgondolni, nem gépenként."
  situations={situations}
  directionsTitle="Milyen elemekből áll össze?"
  directionsLead="A komplett anyagáram nem gépek listája, hanem egy összehangolt rendszer. A fő technológiák köré az előkészítés, az elszívás és az anyagmozgatás illeszkedik, egy közös logika szerint. Ezt egy helyről, több vezető európai gyártó kínálatából tervezzük, egy felelőssel a fogadástól a végtermékig."
  directions={directions}
  faq={faq}
  ctaTitle="Tervezzük meg az anyag teljes útját"
  ctaLead="Mondja el, milyen anyaggal dolgozik, milyen lépések vannak már meg, és hol akad el a folyamat. Ebből összerakjuk a fogadástól a végtermékig tartó rendszert, összehangolt kapacitásokkal és egy felelőssel."
/>
