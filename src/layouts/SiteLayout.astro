---
import BaseLayout from './BaseLayout.astro';
import BrandRail from '../components/site/BrandRail.astro';
import SiteHeader from '../components/site/SiteHeader.astro';
import SiteFooter from '../components/site/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  brand?: string;
}
const { title, description, brand } = Astro.props;
---

<BaseLayout title={title} description={description} brand={brand}>
  <BrandRail />
  <div class="shell">
    <SiteHeader />
    <main><slot /></main>
    <SiteFooter />
  </div>
</BaseLayout>

<style is:global>
  :root { --header-h: 76px; }

  html { scroll-padding-top: var(--header-h); }
  @media (prefers-reduced-motion: no-preference) {
    html { scroll-behavior: smooth; }
  }

  .shell main { padding-top: var(--header-h); }
  @media (min-width: 1024px) {
    .shell { padding-left: var(--sidebar-w); }
  }
</style>
