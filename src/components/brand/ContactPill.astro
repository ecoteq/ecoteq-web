---
/**
 * Outlined contact chip (email / phone) — the signature rail pill.
 * On dark backgrounds: translucent-white stroke + green icon; fills green on hover.
 */
interface Props {
  href: string;
  tone?: 'dark' | 'light';
  class?: string;
  [key: string]: unknown;
}

const { href, tone = 'dark', class: className, ...rest } = Astro.props;
const hasIcon = Astro.slots.has('icon');
---

<a class:list={['contact', className]} data-tone={tone} href={href} {...rest}>
  {hasIcon && <span class="ic"><slot name="icon" /></span>}
  <slot />
</a>

<style>
  .contact {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 9px 16px;
    border-radius: var(--radius-pill);
    font-size: 13px;
    font-weight: var(--fw-semibold);
    letter-spacing: 0.01em;
    text-decoration: none;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--ecoteq-navy);
    transition:
      background var(--dur-base) var(--ease-standard),
      border-color var(--dur-base) var(--ease-standard),
      color var(--dur-base) var(--ease-standard);
  }
  .contact[data-tone='dark'] { border-color: rgba(255, 255, 255, 0.45); color: var(--ecoteq-white); }

  .ic { display: inline-flex; width: 16px; height: 16px; color: var(--color-accent); transition: color var(--dur-base) var(--ease-standard); }
  .ic :global(svg) { width: 100%; height: 100%; }

  .contact:hover { background: var(--color-accent); border-color: var(--color-accent); color: #fff; }
  .contact:hover .ic { color: #fff; }

  @media (prefers-reduced-motion: reduce) { .contact, .ic { transition: none; } }
</style>
