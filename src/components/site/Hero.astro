---
import Overline from '../brand/Overline.astro';
import Button from '../core/Button.astro';
import { CTA } from '../../lib/site';
---

<section class="hero">
  <div class="media">
    <img
      src="/ds/photos/hero-briquette-plant.jpg"
      alt="Ipari brikettáló üzem működés közben"
      fetchpriority="high"
      decoding="async"
    />
    <div class="wash" aria-hidden="true"></div>
  </div>

  <div class="inner">
    <Overline class="eyebrow">Ipari hulladék- és biomassza-feldolgozó rendszerek</Overline>

    <h1>Ipari hulladékból működő anyagáram</h1>

    <p class="lead">
      Ipari darálási, szárítási, brikettálási, pelletálási és elszívási rendszerek
      magyarországi és közép-európai üzemeknek. Nem dobozos gépet adunk, hanem reális
      technológiai irányt.
    </p>

    <div class="ctas">
      <Button href={CTA.primary.href}>{CTA.primary.label}</Button>
      <Button variant="outline-light" href="#technologiak">Megnézem a technológiai irányokat</Button>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    margin-top: calc(-1 * var(--header-h));
    min-height: min(94svh, 900px);
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--ecoteq-navy);
  }

  .media { position: absolute; inset: 0; z-index: 0; }
  .media img { width: 100%; height: 100%; object-fit: cover; }
  .wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(28, 52, 73, 0.95) 0%, rgba(28, 52, 73, 0.74) 48%, rgba(28, 52, 73, 0.22) 100%),
      linear-gradient(0deg, rgba(15, 32, 48, 0.55) 0%, rgba(15, 32, 48, 0) 48%);
  }

  .inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding: calc(var(--header-h) + var(--space-7)) clamp(16px, 4vw, 40px) var(--space-8);
  }

  .eyebrow { color: var(--ecoteq-green); margin-bottom: var(--space-5); }

  h1 {
    color: var(--ecoteq-white);
    font-size: clamp(2.5rem, 1.4rem + 4vw, 5rem);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-display);
    max-width: 15ch;
    margin: 0 0 var(--space-5);
  }

  .lead {
    color: rgba(255, 255, 255, 0.86);
    font-size: var(--fs-lg);
    line-height: var(--lh-body);
    max-width: 54ch;
    margin: 0 0 var(--space-7);
  }

  .ctas { display: flex; flex-wrap: wrap; gap: var(--space-4); }
</style>
