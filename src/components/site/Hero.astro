---
import Overline from '../brand/Overline.astro';
import Button from '../core/Button.astro';
import Icon from '../Icon.astro';
import { CTA } from '../../lib/site';

const trust = [
  '2009 óta ipari technológiák területén',
  'Magyar szakértői támogatás',
  'Európai gyártói háttér',
  'Géptől a komplett rendszerig',
];
---

<section class="hero">
  <div class="media">
    <img
      src="/ds/photos/hero-briquette-plant.jpg"
      alt="Ipari brikettáló üzem működés közben"
      fetchpriority="high"
      decoding="async"
    />
    <div class="wash" aria-hidden="true"></div>
  </div>

  <div class="inner">
    <Overline class="eyebrow">Ipari hulladék- és biomassza-feldolgozó rendszerek</Overline>

    <h1>Ipari hulladékból kezelhető, hasznosítható vagy értékesíthető anyagáram.</h1>

    <p class="lead">
      Az ECOTEQ ipari darálási, szárítási, brikettálási, pelletálási, elszívási és
      anyagmozgatási rendszerekben segít magyarországi és közép-európai üzemeknek. Nem
      dobozos gépet ajánlunk elsőre, hanem megnézzük az anyagot, a mennyiséget, a célt
      és az üzemi körülményeket — és ezek alapján javaslunk technológiai irányt.
    </p>

    <div class="ctas">
      <Button href={CTA.primary.href}>{CTA.primary.label}</Button>
      <Button variant="outline-light" href={CTA.secondary.href}>{CTA.secondary.label}</Button>
    </div>

    <p class="microcopy">
      Néhány alapadat alapján segítünk eldönteni, milyen gép, rendszer vagy
      előkészítési irány lehet reális az Ön üzemében.
    </p>

    <ul class="trust">
      {trust.map((t) => (
        <li><Icon name="check" size={16} /><span>{t}</span></li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    margin-top: calc(-1 * var(--header-h));
    min-height: min(92svh, 880px);
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--ecoteq-navy);
  }

  .media { position: absolute; inset: 0; z-index: 0; }
  .media img { width: 100%; height: 100%; object-fit: cover; }
  .wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(28, 52, 73, 0.94) 0%, rgba(28, 52, 73, 0.7) 42%, rgba(28, 52, 73, 0.18) 100%),
      linear-gradient(0deg, rgba(15, 32, 48, 0.6) 0%, rgba(15, 32, 48, 0) 45%);
  }

  .inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding: calc(var(--header-h) + var(--space-7)) clamp(16px, 4vw, 40px) var(--space-8);
  }

  .eyebrow { color: var(--ecoteq-green); margin-bottom: var(--space-4); }

  h1 {
    color: var(--ecoteq-white);
    font-size: clamp(2.25rem, 1.4rem + 3.4vw, var(--fs-display));
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-display);
    max-width: 17ch;
    margin: 0 0 var(--space-5);
  }

  .lead {
    color: rgba(255, 255, 255, 0.86);
    font-size: var(--fs-lg);
    line-height: var(--lh-body);
    max-width: 60ch;
    margin: 0 0 var(--space-6);
  }

  .ctas { display: flex; flex-wrap: wrap; gap: var(--space-4); }
  .microcopy { color: rgba(255, 255, 255, 0.66); font-size: var(--fs-sm); max-width: 52ch; margin: var(--space-4) 0 var(--space-7); }

  .trust {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
  }
  .trust li { display: inline-flex; align-items: center; gap: 9px; color: rgba(255, 255, 255, 0.9); font-size: var(--fs-sm); font-weight: var(--fw-medium); }
  .trust :global(.icon) { color: var(--ecoteq-green); flex: none; }

  @media (min-width: 1024px) {
    .trust { gap: var(--space-5) var(--space-7); padding-top: var(--space-2); border-top: 1px solid rgba(255, 255, 255, 0.16); }
  }
</style>
