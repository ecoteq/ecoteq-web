---
/* Referenciák / bizonyíték blokk — megnevezett, megvalósult rendszerek (P0-01).
   Karusszel: 3 kártya látszik asztali nézetben, nyílgombokkal + pöttyökkel lapozható,
   mobilon natív swipe (scroll-snap). Egységes 16:9 kártyakép, minden kártyán valós fotó,
   a partner logó/címer/ikon a fotó jobb felső sarkában badge-ként (per-badge --bscale).
   Kártyatest: zöld CAPS kategória → cégnév+hely → elválasztó (azonos magasságban) →
   6 soros rendszerleírás (line-clamp) → diszkrét kiemelt blokk (felirat nélkül).
   A "Biztonsági papírtermék" üzem a megrendelő kérésére NEM nevesíthető (anonim fotó +
   pajzs ikon). Assetek: public/referenciak/. TODO: fotós esettanulmányok /referenciak. */
import Section from '../layout/Section.astro';
import SectionHeading from '../brand/SectionHeading.astro';
import Button from '../core/Button.astro';
import Icon from '../Icon.astro';
import { COMPANY } from '../../lib/site-v2';

const cases = [
  {
    category: 'Komplett brikettáló rendszer',
    org: 'K és B Bioenergia Kft., Szombathely',
    media: { type: 'photo', src: '/referenciak/kesb-640.webp', srcset: '/referenciak/kesb-640.webp 640w, /referenciak/kesb-1280.webp 1280w', alt: 'Zsugorfóliázott kész brikett a csomagoló görgőssorán' },
    badge: { type: 'logo', src: '/referenciak/logok/kesb.png', alt: 'K és B Bioenergia' },
