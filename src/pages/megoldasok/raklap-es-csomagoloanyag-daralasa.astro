// Nyitás-archetípus: konkrét-anyag · Vezető pillér: Anyag-először
import SolutionPage from '../../components/site/SolutionPage.astro';

const trust = [
  { value: 'fémmentes', label: 'szeg- és kapocsleválasztás' },
  { value: 'töredékére', label: 'csökkenő tárolt térfogat' },
  { value: '6', label: 'európai gyártó, egy kézből' },
  { value: '2008', label: 'óta a piacon' },
];

const situations = [
  { icon: 'package', title: 'Helyhiány a sérült és selejt raklapokból', text: 'A használhatatlan raklapok, ládák és csomagolóanyagok terjedelmesen állnak az udvaron, és értékes tárhelyet foglalnak. A felgyűlt mennyiség a napi mozgást is akadályozza.' },
  { icon: 'truck', title: 'Drága és gyakori elszállítás', text: 'A laza, nagy térfogatú hulladék miatt sok a részben üres fuvar, ami feleslegesen növeli a szállítási és a kezelési költségeket.' },
  { icon: 'boxes', title: 'Kezelhetetlen, vegyes anyagáram', text: 'A fa, a karton és a műanyag csomagolóanyag egyben nehezen tárolható és továbbadható. Egységes, kezelhető frakcióra van szükség, bármi legyen a következő lépés.' },
  { icon: 'route', title: 'Anyag-előkészítés a következő lépéshez', text: 'A felaprított anyagot tovább kell adni hasznosításra vagy belső feldolgozásra, ezért egyenletes szemcseméretű, előkészített kimenet a cél.' },
  { icon: 'magnet', title: 'Szegek, fémkapcsok és szennyeződés a raklapokban', text: 'A raklapokban maradó szegek és fémkapcsok védelem nélkül károsíthatják a gépet és ronthatják a végtermék minőségét. A fémleválasztás ezért része a megoldásnak.' },
  { icon: 'recycle', title: 'A hulladékból visszanyerhető anyag', text: 'Az aprított, fémmentes faanyag tüzelőként vagy alapanyagként hasznosítható, így a selejt raklap a költséghelyről az értékteremtés oldalára kerül.' },
];

const directions = [
  { icon: 'shuffle', name: 'Ipari darálás', line: 'Raklap, láda és csomagolóanyag aprítása egyenletes, kezelhető frakcióra.', href: '/technologiak/ipari-daralas/' },
  { icon: 'route', name: 'Anyagmozgatás és rendszerelemek', line: 'Adagolás, kihordás és idegenanyag-leválasztás a darálás köré építve.', href: '/technologiak/anyagmozgas-rendszerelemek/' },
];

const faq = [
  { q: 'Mi van a raklapokban lévő szegekkel és fémkapcsokkal?', a: 'A folyamatba fémleválasztás épül, amely védi a gépet és tisztább végterméket ad. A megoldást a tényleges szennyezettséghez méretezzük.' },
  { q: 'Vegyes fa, karton és műanyag csomagolóanyaggal is működik?', a: 'Igen. A csomagolásnál felmerülő bármilyen anyag jöhet, vegyesen is — az anyagösszetétel alapján választjuk ki az aprítás módját és a frakciót. Érdemes mérlegelni: az alapanyag előzetes szelektálásával értékesebb, tiszta darálási termék keletkezik, ami értékesíthető is lehet, míg a vegyes, szennyezett darálék további felhasználása korlátozottabb, jellemzően energetikai.' },
  { q: 'Mit kezdhetek az aprított anyaggal?', a: 'A fémmentes, egyenletes frakció tárolható, elszállítható, tüzelőként vagy alapanyagként hasznosítható. Hogy melyik éri meg, az anyagtól és a helyi lehetőségektől függ.' },
];
---

<SolutionPage
  title="Raklap és csomagolóanyag darálása"
  description="Raklap, láda és csomagolóanyag darálása térfogatcsökkentésre, kezelhető tárolásra és anyag-előkészítésre, fémleválasztással, több gyártó kínálatából."
  heroLead="Sérült raklap, törött láda, fa és karton csomagolóanyag: nagy térfogatú, vegyes anyag, amely gyorsan elfoglalja a teret és drágán szállítható el. Aprítva egységes, tömör frakcióvá válik, amelyet könnyebb tárolni, elszállítani vagy tovább hasznosítani. A megfelelő irány attól függ, mi van benne, mennyi, és mi a célja vele."
  heroImage="/heroes/hero-raklap.jpg"
  heroImageAlt="ECOTEQ raklap- és csomagolóanyag-daráló üzemi környezetben"
  source="megoldas-raklap-csomagoloanyag"
  situationsTitle="Mikor válik teherré a selejt raklap és csomagolóanyag?"
  situationsLead="Az alábbi helyzetekben érdemes átgondolni a felgyűlő raklap és csomagolóanyag sorsát."
  trust={trust}
  situations={situations}
  directionsLead="A raklap és a csomagolóanyag darálása ritkán csak egy gép. A tartós eredményhez az aprítás, a fémleválasztás és az anyag kihordása összehangoltan működik. Ezt egy helyről, több vezető gyártó kínálatából állítjuk össze, a benne lévő szennyeződésekhez és a kívánt frakcióhoz igazítva."
  directions={directions}
  faq={faq}
  ctaTitle="Nézzük meg, mi van a raklapban"
  ctaLead="Mondja el, milyen raklap és csomagolóanyag gyűlik az üzemében, mennyi, és mi benne a szennyeződés. Ebből meghatározzuk az aprítás módját, a szükséges fémleválasztást és a kihordást, hogy kezelhető anyag és kevesebb fuvar legyen az eredmény."
/>
