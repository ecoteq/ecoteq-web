---
import Section from '../layout/Section.astro';
import SectionHeading from '../brand/SectionHeading.astro';
import Icon from '../Icon.astro';

const entries = [
  {
    title: 'Sok a faipari hulladék, forgács vagy por',
    text: 'Megnézzük, hogy darálásra, brikettálásra, elszívásra, szárításra vagy ezek kombinációjára van-e szükség.',
    cta: 'Faipari hulladék kezelése',
  },
  {
    title: 'Raklapot, ládát vagy csomagolóanyagot kell aprítani',
    text: 'A cél lehet térfogatcsökkentés, kezelhetőbb tárolás, további feldolgozás vagy anyag-előkészítés.',
    cta: 'Raklap és csomagolóanyag darálása',
  },
  {
    title: 'Nedves biomasszát kell kezelhető állapotba hozni',
    text: 'Ilyenkor a szárítás, az energiaigény, a frakció és az utólagos felhasználás együtt határozza meg a jó irányt.',
    cta: 'Biomassza-szárítási irányt kérek',
  },
  {
    title: 'Brikettet vagy pelletet szeretne gyártani',
    text: 'A döntéshez nem elég a gépkapacitás — fontos az alapanyag, a nedvesség, a szemcseméret, az üzemóra és a cél.',
    cta: 'Brikettálás vagy pelletálás előminősítése',
  },
  {
    title: 'Faanyagot kell gyorsabban és kontrolláltabban szárítani',
    text: 'A vákuumszárítás akkor lehet jó irány, ha a ciklusidő, a minőség, a repedéskockázat és a tervezhető gyártás fontos.',
    cta: 'Vákuumszárítási konzultáció',
  },
  {
    title: 'Nem tudja, milyen technológia kell',
    text: 'Ez teljesen normális. Írja le az anyagot és a célt, mi pedig segítünk kiválasztani az első reális irányt.',
    cta: 'Leírom a feladatot',
  },
];
---

<Section id="megoldasok" surface="subtle">
  <SectionHeading
    overline="Megoldások"
    title="Nem biztos, hogy gépre van szüksége — lehet, hogy először a technológiai irányt kell tisztázni"
    lead="Sok ipari projekt ott csúszik el, hogy túl korán kezdődik a gépválasztás. Ugyanarra az anyagra más megoldás kellhet, ha a cél a térfogatcsökkentés, más, ha brikettálás, és megint más, ha a fő gond a nedvesség, a por vagy az anyagmozgatás."
  />

  <div class="grid">
    {entries.map((e) => (
      <a class="entry" href="#ajanlatkeres">
        <h3>{e.title}</h3>
        <p>{e.text}</p>
        <span class="cta">{e.cta} <Icon name="arrow-right" size={16} /></span>
      </a>
    ))}
  </div>
</Section>

<style>
  .grid {
    margin-top: var(--space-7);
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }
  .entry {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    border-top: 3px solid var(--color-accent);
    padding: var(--space-5);
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--dur-base) var(--ease-standard), transform var(--dur-base) var(--ease-standard), border-color var(--dur-base) var(--ease-standard);
  }
  .entry:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .entry h3 { margin: 0; font-size: var(--fs-h4); font-weight: var(--fw-bold); color: var(--color-text); }
  .entry p { margin: 0; font-size: var(--fs-sm); color: var(--color-text-secondary); line-height: var(--lh-snug); }
  .cta {
    margin-top: auto;
    padding-top: var(--space-3);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-accent-text);
    font-weight: var(--fw-bold);
    font-size: var(--fs-sm);
    transition: gap var(--dur-base) var(--ease-standard);
  }
  .entry:hover .cta { gap: 12px; }
  @media (prefers-reduced-motion: reduce) {
    .entry, .cta { transition: none; }
    .entry:hover { transform: none; }
  }
</style>
