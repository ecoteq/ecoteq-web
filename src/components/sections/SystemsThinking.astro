---
import Section from '../layout/Section.astro';
import SectionHeading from '../brand/SectionHeading.astro';
import Button from '../core/Button.astro';
import { CTA } from '../../lib/site';

const pillars = [
  {
    title: 'Anyag és mennyiség',
    text: 'Milyen anyag keletkezik, milyen formában, nedvességgel és mennyiségben? Innen indul minden döntés.',
  },
  {
    title: 'Technológiai irány',
    text: 'Darálás, szárítás, brikettálás, pelletálás, elszívás vagy ezek kombinációja — a feladathoz illesztve.',
  },
  {
    title: 'Működő rendszer és támogatás',
    text: 'Adagolás, anyagmozgatás, telepítés, szerviz és bővíthetőség, hogy a rendszer az üzemben is működjön.',
  },
];
---

<Section surface="navy">
  <SectionHeading
    tone="dark"
    overline="ECOTEQ szemlélet"
    title="Nem gépet választunk először. Anyagot, célt és üzemi realitást tisztázunk"
    lead="Az ipari hulladék és biomassza kezelése akkor működik jól, ha az anyag útja végig van gondolva — a gép csak ezután jön."
  />

  <div class="pillars">
    {pillars.map((p, i) => (
      <div class="pillar">
        <span class="num">{String(i + 1).padStart(2, '0')}</span>
        <h3>{p.title}</h3>
        <p>{p.text}</p>
      </div>
    ))}
  </div>

  <Button variant="outline-light" href={CTA.primary.href}>Konzultációt kérek a rendszerirányról</Button>
</Section>

<style>
  .pillars {
    margin: var(--space-8) 0;
    display: grid;
    gap: var(--space-6) var(--space-7);
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) { .pillars { grid-template-columns: repeat(3, 1fr); } }

  .num {
    display: block;
    font-family: var(--font-display);
    font-weight: var(--fw-extrabold);
    font-size: var(--fs-h2);
    line-height: 1;
    letter-spacing: var(--ls-display);
    color: var(--ecoteq-green);
    margin-bottom: var(--space-4);
  }
  .pillar h3 { margin: 0 0 var(--space-2); font-size: var(--fs-h3); font-weight: var(--fw-bold); color: var(--ecoteq-white); }
  .pillar p { margin: 0; color: rgba(255, 255, 255, 0.78); line-height: var(--lh-body); }
</style>
