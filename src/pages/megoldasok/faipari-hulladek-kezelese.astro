---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeading from '../../components/brand/SectionHeading.astro';
import Button from '../../components/core/Button.astro';
import Icon from '../../components/Icon.astro';

const situations = [
  {
    icon: 'wind',
    text: 'A megmunkálás során folyamatosan keletkező por és forgács terheli a munkateret és a gépeket.',
  },
  {
    icon: 'boxes',
    text: 'A laza fahulladék és apríték sok helyet foglal, így a tárolása és a mozgatása nehézkes.',
  },
  {
    icon: 'shuffle',
    text: 'A vegyes méretű hulladék – darabos fahulladék, apríték, forgács – nem egységes, ezért nehezen kezelhető.',
  },
  {
    icon: 'recycle',
    text: 'A keletkező mellékanyag jelenleg elszállítandó hulladék, pedig hasznosítható alapanyag is lehetne.',
  },
  {
    icon: 'factory',
    text: 'A rendezetlen anyagáram lassítja a termelést és kiszámíthatatlanná teszi az üzemi folyamatokat.',
  },
];

const directions = [
  {
    icon: 'shuffle',
    name: 'Ipari darálás',
    line: 'A faipari hulladék aprítása, térfogatcsökkentés',
    href: '/technologiak/ipari-daralas/',
  },
  {
    icon: 'wind',
    name: 'Elszívás és porleválasztás',
    line: 'A por és forgács elszívása, leválasztása',
    href: '/technologiak/elszivas-porlevalasztas/',
  },
  {
    icon: 'flame',
    name: 'Brikettálás',
    line: 'A száraz mellékanyag tömörítése briketté',
    href: '/technologiak/brikettalas/',
  },
];
---

<SiteLayout
  title="Faipari hulladék kezelése"
  description="Forgács, por, apríték és fahulladék rendezett kezelése faipari üzemekben – darálás, elszívás és brikettálás kombinációjával."
  solidHeader
>
  <Section surface="subtle">
    <nav class="crumb" aria-label="Útvonal">
      <a href="/">Főoldal</a> <span>/</span>
      <a href="/#megoldasok">Megoldások</a> <span>/</span>
      <span class="here">Faipari hulladék kezelése</span>
    </nav>
    <SectionHeading
      overline="Megoldás"
      title="Faipari hulladék kezelése"
      lead="A faipari üzemekben keletkező forgács, por, apríték és fahulladék rendezett kezelése kézzelfogható különbséget jelent. Darálás, elszívás és brikettálás kombinációjával az anyag kezelhetőbb, tárolhatóbb és hasznosítható lesz."
      as="h1"
    />
    <div class="cta">
      <Button href="/#ajanlatkeres">Technológiai irányt kérek</Button>
    </div>
  </Section>

  <Section surface="white">
    <SectionHeading
      overline="Helyzetkép"
      title="Mikor merül fel?"
      lead="Az alábbi üzemi helyzetekben érdemes átgondolni a faipari hulladék kezelését."
    />
    <ul class="grid" role="list">
      {
        situations.map((item) => (
          <li class="card">
            <span class="card-ic" aria-hidden="true">
              <Icon name={item.icon} size={22} />
            </span>
            <p class="card-text">{item.text}</p>
          </li>
        ))
      }
    </ul>
  </Section>

  <Section surface="subtle">
    <SectionHeading
      overline="Technológiai irány"
      title="Milyen technológiai irány segíthet?"
      lead="A faipari hulladék kezelése ritkán egyetlen géptől függ. A legtöbb üzemben az alábbi technológiák összehangolt használata vezet rendezett, hasznosítható anyagáramhoz."
    />
    <div class="tech-grid">
      {
        directions.map((tech) => (
          <a class="tech" href={tech.href}>
            <span class="tech-ic" aria-hidden="true">
              <Icon name={tech.icon} size={24} />
            </span>
            <span class="tech-body">
              <span class="tech-name">{tech.name}</span>
              <span class="tech-line">{tech.line}</span>
            </span>
            <span class="tech-arrow" aria-hidden="true">
              <Icon name="arrow-right" size={20} />
            </span>
          </a>
        ))
      }
    </div>
  </Section>

  <Section surface="navy">
    <SectionHeading
      tone="dark"
      title="Beszéljük át a faipari hulladék útját"
      lead="Mondja el, milyen anyag keletkezik az üzemében, és közösen meghatározzuk, hogy a darálás, az elszívás és a brikettálás milyen kombinációja illik a folyamataihoz."
    />
    <div class="cta">
      <Button href="/#ajanlatkeres">Technológiai irányt kérek</Button>
    </div>
  </Section>
</SiteLayout>

<style>
  .crumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }
  .crumb a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .crumb .here {
    color: var(--color-text);
  }
  .cta {
    margin-top: var(--space-6);
  }

  .grid {
    list-style: none;
    margin: var(--space-7) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4);
  }
  .card {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
    padding: var(--space-5);
    background: var(--color-bg-subtle);
    border-radius: var(--radius-lg);
  }
  .card-ic {
    display: inline-flex;
    flex: none;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: var(--color-accent-tint);
    color: var(--color-accent-active);
  }
  .card-text {
    margin: 0;
    font-size: var(--fs-base);
    line-height: var(--lh-body);
    color: var(--color-text-secondary);
  }

  .tech-grid {
    margin-top: var(--space-7);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-4);
  }
  .tech {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-5);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition:
      border-color var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }
  .tech:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-sm);
    transform: translateY(-2px);
  }
  .tech-ic {
    display: inline-flex;
    flex: none;
    width: 48px;
    height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: var(--color-accent-tint);
    color: var(--color-accent-active);
  }
  .tech-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1 1 auto;
  }
  .tech-name {
    font-family: var(--font-display);
    font-weight: var(--fw-bold);
    font-size: var(--fs-lg);
    color: var(--color-text);
  }
  .tech-line {
    font-size: var(--fs-sm);
    line-height: var(--lh-body);
    color: var(--color-text-secondary);
  }
  .tech-arrow {
    display: inline-flex;
    flex: none;
    color: var(--color-text-muted);
    transition:
      color var(--dur-base) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }
  .tech:hover .tech-arrow {
    color: var(--color-accent);
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .tech,
    .tech-arrow {
      transition: none;
    }
    .tech:hover,
    .tech:hover .tech-arrow {
      transform: none;
    }
  }
</style>
