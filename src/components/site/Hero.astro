---
import Overline from '../brand/Overline.astro';
import Button from '../core/Button.astro';
import Icon from '../Icon.astro';
import { CTA } from '../../lib/site';

const trust = [
  { icon: 'calendar', text: '2009 óta ipari technológiák területén' },
  { icon: 'map-pin', text: 'Magyar szakértői támogatás' },
  { icon: 'globe', text: 'Európai gyártói háttér' },
  { icon: 'layers', text: 'Géptől a komplett rendszerig' },
] as const;
---

<section class="hero">
  <div class="media">
    <img
      src="/ds/photos/hero-briquette-plant.jpg"
      alt="Ipari brikettáló üzem működés közben"
      fetchpriority="high"
      decoding="async"
    />
    <div class="wash" aria-hidden="true"></div>
  </div>

  <div class="inner">
    <Overline class="eyebrow">Ipari hulladék- és biomassza-feldolgozó rendszerek</Overline>

    <h1>Ipari hulladékból hasznosítható termék</h1>

    <p class="lead">
      Az ECOTEQ ipari darálási, szárítási, brikettálási, pelletálási, elszívási és
      anyagmozgatási rendszerekben segít magyarországi és közép-európai üzemeknek. Nem
      dobozos gépet ajánlunk elsőre, hanem megnézzük az anyagot, a mennyiséget, a célt
      és az üzemi körülményeket — és ezek alapján javaslunk technológiai irányt.
    </p>

    <div class="ctas">
      <Button href={CTA.primary.href}>{CTA.primary.label}</Button>
      <Button variant="outline-light" href={CTA.secondary.href}>{CTA.secondary.label}</Button>
    </div>

    <p class="microcopy">
      Néhány alapadat alapján segítünk eldönteni, milyen gép, rendszer vagy
      előkészítési irány lehet reális az Ön üzemében.
    </p>

    <ul class="trust">
      {trust.map((t) => (
        <li>
          <span class="badge"><Icon name={t.icon} size={20} /></span>
          <span class="t-text">{t.text}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero {
    position: relative;
    margin-top: calc(-1 * var(--header-h));
    min-height: min(92svh, 880px);
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--ecoteq-navy);
  }

  .media { position: absolute; inset: 0; z-index: 0; }
  .media img { width: 100%; height: 100%; object-fit: cover; }
  .wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(28, 52, 73, 0.94) 0%, rgba(28, 52, 73, 0.7) 42%, rgba(28, 52, 73, 0.18) 100%),
      linear-gradient(0deg, rgba(15, 32, 48, 0.6) 0%, rgba(15, 32, 48, 0) 45%);
  }

  .inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding: calc(var(--header-h) + var(--space-7)) clamp(16px, 4vw, 40px) var(--space-8);
  }

  .eyebrow { color: var(--ecoteq-green); margin-bottom: var(--space-4); }

  h1 {
    color: var(--ecoteq-white);
    font-size: clamp(2.25rem, 1.4rem + 3.4vw, var(--fs-display));
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-display);
    max-width: 17ch;
    margin: 0 0 var(--space-5);
  }

  .lead {
    color: rgba(255, 255, 255, 0.86);
    font-size: var(--fs-lg);
    line-height: var(--lh-body);
    max-width: 60ch;
    margin: 0 0 var(--space-6);
  }

  .ctas { display: flex; flex-wrap: wrap; gap: var(--space-4); }
  .microcopy { color: rgba(255, 255, 255, 0.66); font-size: var(--fs-sm); max-width: 52ch; margin: var(--space-4) 0 var(--space-7); }

  .trust {
    list-style: none;
    margin: var(--space-7) 0 0;
    padding: var(--space-5) var(--space-6);
    width: 100%;
    display: grid;
    gap: var(--space-4) var(--space-6);
    grid-template-columns: 1fr;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius-lg);
    backdrop-filter: blur(3px);
  }
  @media (min-width: 560px) { .trust { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1080px) { .trust { grid-template-columns: repeat(4, 1fr); } }

  .trust li { display: flex; align-items: center; gap: 12px; }
  .badge {
    flex: none;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-pill);
    display: grid;
    place-items: center;
    background: rgba(67, 173, 77, 0.18);
    border: 1px solid rgba(67, 173, 77, 0.4);
    color: var(--ecoteq-green);
  }
  .t-text { color: rgba(255, 255, 255, 0.95); font-size: var(--fs-sm); font-weight: var(--fw-semibold); line-height: 1.25; }
</style>
