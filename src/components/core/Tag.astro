---
/** Pill tag / category label. Green is the signature; navy & subtle variants too. */
interface Props {
  variant?: 'green' | 'navy' | 'subtle' | 'outline-light';
  size?: 'sm' | 'md';
  uppercase?: boolean;
  class?: string;
  [key: string]: unknown;
}

const { variant = 'green', size = 'md', uppercase = true, class: className, ...rest } = Astro.props;
const hasIcon = Astro.slots.has('icon');
---

<span
  class:list={['tag', className]}
  data-variant={variant}
  data-size={size}
  data-upper={uppercase ? '' : undefined}
  {...rest}
>
  {hasIcon && <span class="ic"><slot name="icon" /></span>}
  <slot />
</span>

<style>
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border-radius: var(--radius-pill);
    font-weight: var(--fw-bold);
    letter-spacing: 0.02em;
  }
  .tag[data-upper] { text-transform: uppercase; letter-spacing: var(--ls-overline); }
  .tag[data-size='sm'] { padding: 4px 11px; font-size: 10px; }
  .tag[data-size='md'] { padding: 6px 15px; font-size: 11px; }

  .ic { display: inline-flex; width: 13px; height: 13px; }
  .ic :global(svg) { width: 100%; height: 100%; }

  .tag[data-variant='green'] { background: var(--color-cta); color: var(--color-on-accent); }
  .tag[data-variant='navy'] { background: var(--ecoteq-navy); color: #fff; }
  .tag[data-variant='subtle'] { background: var(--color-accent-tint); color: var(--green-700); }
  .tag[data-variant='outline-light'] {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.5);
  }
</style>
