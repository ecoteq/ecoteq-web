---
import Section from '../layout/Section.astro';
import SectionHeading from '../brand/SectionHeading.astro';
import Button from '../core/Button.astro';
import Icon from '../Icon.astro';

const articles = [
  { title: 'Mekkora daráló kell faipari hulladékhoz?', text: 'Rövid útmutató anyag, méret, frakció, kapacitás és további feldolgozási cél alapján.' },
  { title: 'Mikor éri meg brikettálni?', text: 'A brikettálás nem minden üzemnek ugyanúgy jó — a döntéshez anyagmennyiség, nedvesség, üzemóra és felhasználási cél is kell.' },
  { title: 'Miért fontos a nedvesség brikettálás és pelletálás előtt?', text: 'A nedvességtartalom hatással van a tömörítésre, a végtermékre, az energiaigényre és az üzembiztonságra.' },
  { title: 'Mikor lehet jó választás a vákuumszárító?', text: 'Faipari üzemeknek, ahol a szárítási idő, a minőség és a gyártási kiszámíthatóság kulcskérdés.' },
];
---

<Section id="tudastar" surface="white">
  <SectionHeading
    overline="Tudástár"
    title="Döntés előtt érdemes tisztázni az alapokat"
    lead="A jó beruházási döntéshez nem kell mindent tudnia a gépekről, de néhány alapfogalom sok félreértést megelőz. Rövid, gyakorlatias anyagokkal segítünk eligazodni."
  />

  <div class="grid">
    {articles.map((a) => (
      <a class="article" href="#tudastar">
        <h3>{a.title}</h3>
        <p>{a.text}</p>
        <span class="cta">Elolvasom <Icon name="arrow-right" size={16} /></span>
      </a>
    ))}
  </div>

  <div class="cta-wrap">
    <Button variant="secondary" href="#tudastar">Megnézem a tudástárat</Button>
  </div>
</Section>

<style>
  .grid {
    margin-top: var(--space-7);
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 680px) { .grid { grid-template-columns: 1fr 1fr; } }

  .article {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    text-decoration: none;
    color: inherit;
    transition: box-shadow var(--dur-base) var(--ease-standard), transform var(--dur-base) var(--ease-standard);
  }
  .article:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .article h3 { margin: 0; font-size: var(--fs-h4); font-weight: var(--fw-bold); color: var(--color-text); }
  .article p { margin: 0; font-size: var(--fs-sm); color: var(--color-text-secondary); line-height: var(--lh-snug); }
  .cta {
    margin-top: var(--space-2);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-accent-text);
    font-weight: var(--fw-bold);
    font-size: var(--fs-sm);
    transition: gap var(--dur-base) var(--ease-standard);
  }
  .article:hover .cta { gap: 12px; }

  .cta-wrap { margin-top: var(--space-7); }
  @media (prefers-reduced-motion: reduce) {
    .article, .cta { transition: none; }
    .article:hover { transform: none; }
  }
</style>
