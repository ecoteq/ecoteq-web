---
import SiteLayout from './SiteLayout.astro';

interface Props {
  title: string;
  updated?: string;
  description?: string;
}
const { title, updated, description } = Astro.props;
---

<SiteLayout title={title} description={description} solidHeader>
  <article class="legal">
    <nav class="crumb" aria-label="Útvonal">
      <a href="/">Főoldal</a><span aria-hidden="true">/</span><span class="here">{title}</span>
    </nav>
    <header class="head">
      <h1>{title}</h1>
      {updated && <p class="updated">Hatályos: {updated}</p>}
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</SiteLayout>

<style>
  .legal { max-width: 820px; margin-inline: auto; padding: var(--space-8) clamp(16px, 4vw, 40px) var(--space-10); }

  .crumb { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; font-size: var(--fs-sm); color: var(--color-text-muted); margin-bottom: var(--space-5); }
  .crumb a { color: var(--color-text-secondary); text-decoration: none; }
  .crumb a:hover { color: var(--color-accent-text); }

  .head { padding-bottom: var(--space-5); border-bottom: 1px solid var(--color-border); margin-bottom: var(--space-7); }
  .head h1 { margin: 0; font-size: var(--fs-h1); letter-spacing: var(--ls-display); }
  .updated { margin: var(--space-3) 0 0; font-size: var(--fs-xs); font-weight: var(--fw-bold); letter-spacing: var(--ls-overline); text-transform: uppercase; color: var(--color-text-muted); }

  .prose :global(h2) { font-size: var(--fs-h3); margin: var(--space-7) 0 var(--space-3); color: var(--color-text); }
  .prose :global(h3) { font-size: var(--fs-h4); margin: var(--space-5) 0 var(--space-2); color: var(--color-text); }
  .prose :global(p) { margin: 0 0 var(--space-4); line-height: var(--lh-body); color: var(--color-text-secondary); }
  .prose :global(strong) { color: var(--color-text); font-weight: var(--fw-semibold); }
  .prose :global(a) { color: var(--color-accent-text); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(ul) { margin: 0 0 var(--space-4); padding-left: var(--space-5); color: var(--color-text-secondary); line-height: var(--lh-body); }
  .prose :global(li) { margin-bottom: 6px; }

  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 0 0 var(--space-5); font-size: var(--fs-sm); }
  .prose :global(th) { text-align: left; background: var(--color-bg-subtle); color: var(--ecoteq-navy); font-weight: var(--fw-bold); padding: 10px 14px; border: 1px solid var(--color-border); }
  .prose :global(td) { padding: 10px 14px; border: 1px solid var(--color-border); color: var(--color-text-secondary); vertical-align: top; }
</style>
