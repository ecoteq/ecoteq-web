const isFilled = FILLED.has(name);

const dim = size != null ? (typeof size === 'number' ? `${size}px` : size) : undefined;
const decorative = !ariaLabel;
---

<svg
  class:list={['icon', className]}
  viewBox="0 0 24 24"
  fill={isFilled ? 'currentColor' : 'none'}
  stroke={isFilled ? undefined : 'currentColor'}
  stroke-width={isFilled ? undefined : '1.75'}
  stroke-linecap="round"
  stroke-linejoin="round"
  width={dim}
  height={dim}
  role={decorative ? undefined : 'img'}
  aria-hidden={decorative ? 'true' : undefined}
  aria-label={ariaLabel}
  set:html={paths[name]}
  {...rest}
/>

<style>
  .icon { display: inline-block; flex: none; }
  /* When no explicit size: fill the parent box (used inside Button/ContactPill slots). */
  .icon:not([width]) { width: 100%; height: 100%; }
</style>
