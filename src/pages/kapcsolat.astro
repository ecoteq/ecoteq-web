---
import SiteLayout from '../layouts/SiteLayout.astro';
import Section from '../components/layout/Section.astro';
import SectionHeading from '../components/brand/SectionHeading.astro';
import Button from '../components/core/Button.astro';
import Icon from '../components/Icon.astro';
import { CONTACT, quoteHref } from '../lib/site';

const checklist = [
  { label: 'Anyag', text: 'Milyen anyag keletkezik (faforgács, por, fólia, vegyes ipari hulladék)?' },
  { label: 'Mennyiség', text: 'Mekkora a napi vagy heti mennyiség, és mennyire ingadozik?' },
  { label: 'Cél', text: 'Mi a cél: térfogatcsökkentés, hasznosítás, értékesítés vagy energetikai felhasználás?' },
  { label: 'Telepítés helye', text: 'Hol és milyen üzemi környezetben kell a megoldásnak működnie?' },
];
---

<SiteLayout
  title="Kapcsolat"
  description="ECOTEQ Kft. elérhetőségei és cégadatai. Írjon nekünk, vagy küldje el a projekt adatait a rövid előminősítő űrlapon."
  solidHeader
>
  <Section surface="subtle">
    <nav class="crumb" aria-label="Útvonal"><a href="/">Főoldal</a> <span aria-hidden="true">|</span> <span class="here">Kapcsolat</span></nav>
    <SectionHeading
      overline="Kapcsolat"
      title="Vegye fel velünk a kapcsolatot"
      lead="Elérhetőségek, cégadatok és közvetlen kapcsolat. Ha konkrét üzemi feladata van, a leggyorsabb út a rövid előminősítő űrlap."
      as="h1"
    />
  </Section>

  <Section surface="white">
    <div class="split">
      <div class="details">
        <SectionHeading overline="Elérhetőségek" title="Cégadatok és közvetlen kapcsolat" />
        <ul class="contact" role="list">
          <li class="row">
            <span class="row-ic" aria-hidden="true"><Icon name="map-pin" size={20} /></span>
            <span class="row-body">
              <span class="row-label">{CONTACT.company}</span>
              <span class="row-value">{CONTACT.address}</span>
            </span>
          </li>
          <li class="row">
            <span class="row-ic" aria-hidden="true"><Icon name="mail" size={20} /></span>
            <span class="row-body">
              <span class="row-label">E-mail</span>
              <a class="row-link" href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
            </span>
          </li>
          <li class="row">
            <span class="row-ic" aria-hidden="true"><Icon name="phone" size={20} /></span>
            <span class="row-body">
              <span class="row-label">Telefon</span>
              <a class="row-link" href={CONTACT.phoneHref}>{CONTACT.phone}</a>
            </span>
          </li>
        </ul>
        <!-- TODO: térkép beágyazás (Csillaghegyi út 19–21.) -->
      </div>

      <div class="reach">
        <SectionHeading overline="Előminősítés" title="Mit érdemes megírnia?" />
        <ul class="checklist" role="list">
          {checklist.map((item) => (
            <li class="check">
              <span class="check-ic" aria-hidden="true"><Icon name="check" size={16} /></span>
              <span class="check-body">
                <span class="check-label">{item.label}</span>
                <span class="check-text">{item.text}</span>
              </span>
            </li>
          ))}
        </ul>
        <div class="cta"><Button href={quoteHref(undefined, 'kapcsolat')}>Technológiai javaslatot kérek</Button></div>
      </div>
    </div>
  </Section>

  <Section surface="navy">
    <div class="closing">
      <SectionHeading
        tone="dark"
        title="Beszéljünk a feladatról, mielőtt gépről beszélnénk"
        lead="Mondja el, milyen anyaggal és milyen céllal dolgozik. Megnézzük az egész anyagutat, és olyan technológiai irányt javaslunk, amely üzletileg is vállalható."
      />
      <div class="cta"><Button href={quoteHref(undefined, 'kapcsolat')}>Technológiai javaslatot kérek</Button></div>
    </div>
  </Section>
</SiteLayout>

<style>
  .crumb{display:flex;flex-wrap:wrap;gap:8px;align-items:center;font-size:var(--fs-sm);color:var(--color-text-muted);margin-bottom:var(--space-5)}
  .crumb a{color:var(--color-text-secondary);text-decoration:none}
  .crumb a:hover{color:var(--color-accent)}
  .crumb .here{color:var(--color-text)}
  .cta{margin-top:var(--space-6)}

  /* two-column layout */
  .split{display:grid;gap:var(--space-8);grid-template-columns:1fr}
  @media (min-width:900px){.split{grid-template-columns:1fr 1fr;align-items:start;gap:var(--space-9)}}

  /* contact details */
  .contact{list-style:none;margin:var(--space-6) 0 0;padding:0;display:flex;flex-direction:column;gap:var(--space-4)}
  .row{display:flex;align-items:flex-start;gap:var(--space-4);padding:var(--space-4) var(--space-5);background:var(--color-bg-subtle);border:1px solid var(--color-border);border-radius:var(--radius-md)}
  .row-ic{display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;flex:none;border-radius:var(--radius-md);background:var(--color-bg);color:var(--color-accent);border:1px solid var(--color-border)}
  .row-body{display:flex;flex-direction:column;gap:3px;min-width:0}
  .row-label{font-family:var(--font-display);font-weight:var(--fw-bold);font-size:var(--fs-base);color:var(--color-text)}
  .row-value{font-size:var(--fs-base);color:var(--color-text-secondary)}
  .row-link{font-size:var(--fs-base);color:var(--color-text-secondary);text-decoration:none}
  .row-link:hover{color:var(--color-accent)}

  /* checklist */
  .checklist{list-style:none;margin:var(--space-6) 0 0;padding:0;display:flex;flex-direction:column;gap:var(--space-4)}
  .check{display:flex;align-items:flex-start;gap:var(--space-3)}
  .check-ic{display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;flex:none;border-radius:var(--radius-pill);background:var(--color-accent-tint);color:var(--color-accent)}
  .check-body{display:flex;flex-direction:column;gap:2px}
  .check-label{font-family:var(--font-display);font-weight:var(--fw-bold);font-size:var(--fs-base);color:var(--color-text)}
  .check-text{font-size:var(--fs-base);line-height:var(--lh-body);color:var(--color-text-secondary)}

  .closing{display:flex;flex-direction:column;align-items:flex-start;gap:var(--space-2)}
</style>
