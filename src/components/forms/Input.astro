---
/** Text input with label, optional required marker, leading icon, hint/error.
    Filled field on a soft surface; crisp accent focus ring; squarer 8px radius. */
interface Props {
  label?: string;
  hint?: string;
  error?: string;
  id?: string;
  name?: string;
  type?: string;
  placeholder?: string;
  required?: boolean;
  value?: string;
  class?: string;
  [key: string]: unknown;
}

const { label, hint, error, id, required, class: className, ...rest } = Astro.props;
const slug = label ? String(label).toLowerCase().replace(/\s+/g, '-') : 'field';
const inputId = id ?? `in-${slug}`;
const describedBy = error || hint ? `${inputId}-msg` : undefined;
const hasIcon = Astro.slots.has('icon');
---

<div class:list={['field', className]}>
  {label && (
    <label class="label" for={inputId}>
      {label}{required && <span class="req" aria-hidden="true">*</span>}
    </label>
  )}
  <div class="control" data-has-icon={hasIcon ? '' : undefined}>
    {hasIcon && <span class="ic" aria-hidden="true"><slot name="icon" /></span>}
    <input
      id={inputId}
      class="input"
      required={required}
      data-error={error ? '' : undefined}
      aria-invalid={error ? 'true' : undefined}
      aria-describedby={describedBy}
      {...rest}
    />
  </div>
  {(error || hint) && (
    <span id={describedBy} class="msg" data-error={error ? '' : undefined}>{error || hint}</span>
  )}
</div>

<style>
  .field { display: flex; flex-direction: column; gap: 7px; }
  .label {
    font-size: var(--fs-sm);
    font-weight: var(--fw-semibold);
    color: var(--color-text);
    letter-spacing: 0.005em;
  }
  .req { color: var(--color-accent-text); font-weight: var(--fw-bold); margin-left: 3px; }

  .control { position: relative; display: flex; align-items: center; }
  .ic {
    position: absolute;
    left: 15px;
    display: inline-flex;
    width: 18px;
    height: 18px;
    color: var(--color-text-muted);
    pointer-events: none;
  }
  .ic :global(svg) { width: 100%; height: 100%; }

  .input {
    width: 100%;
    box-sizing: border-box;
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.4;
    color: var(--color-text);
    background: var(--color-input-bg);
    border: 1px solid var(--color-input-border);
    border-radius: var(--radius-md);
    padding: 13px 15px;
    transition:
      border-color var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard),
      background var(--dur-base) var(--ease-standard);
  }
  .control[data-has-icon] .input { padding-left: 44px; }
  .input::placeholder { color: var(--color-text-muted); }
  .input:hover { border-color: var(--color-border-strong); }
  .input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-ring);
  }
  .input[data-error] { border-color: var(--color-danger); }
  .input[data-error]:focus { box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-danger) 22%, transparent); }

  .msg { font-size: var(--fs-xs); color: var(--color-text-secondary); }
  .msg[data-error] { color: var(--color-danger); }

  @media (prefers-reduced-motion: reduce) { .input { transition: none; } }
</style>
