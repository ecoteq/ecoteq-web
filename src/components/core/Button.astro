---
/**
 * ECOTEQ button. Primary = green capsule CTA (the "Ajánlat kérés" shape).
 * Renders <a> when `href` is set, otherwise <button>.
 * Icons go in the `icon-left` / `icon-right` slots.
 */
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost' | 'outline-light';
  size?: 'sm' | 'md' | 'lg';
  pill?: boolean;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  class?: string;
  [key: string]: unknown;
}

const {
  variant = 'primary',
  size = 'md',
  pill = true,
  href,
  type = 'button',
  disabled = false,
  class: className,
  ...rest
} = Astro.props;

const Tag = href ? 'a' : 'button';
const hasLeft = Astro.slots.has('icon-left');
const hasRight = Astro.slots.has('icon-right');
---

<Tag
  class:list={['btn', className]}
  data-variant={variant}
  data-size={size}
  data-pill={pill ? '' : undefined}
  href={href}
  type={href ? undefined : type}
  disabled={href ? undefined : disabled}
  aria-disabled={href && disabled ? 'true' : undefined}
  {...rest}
>
  {hasLeft && <span class="ic"><slot name="icon-left" /></span>}
  <slot />
  {hasRight && <span class="ic"><slot name="icon-right" /></span>}
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-sans);
    font-weight: var(--fw-bold);
    letter-spacing: 0.02em;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    border: 1.5px solid transparent;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition:
      background var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard),
      border-color var(--dur-base) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }
  .btn[data-pill] { border-radius: var(--radius-pill); }
  .btn:disabled,
  .btn[aria-disabled='true'] { opacity: 0.5; cursor: not-allowed; }

  /* sizes */
  .btn[data-size='sm'] { padding: 8px 16px; font-size: 13px; gap: 7px; }
  .btn[data-size='md'] { padding: 12px 24px; font-size: 15px; gap: 9px; }
  .btn[data-size='lg'] { padding: 16px 32px; font-size: 16px; gap: 10px; }
  .btn[data-size='sm'] .ic { width: 16px; height: 16px; }
  .btn[data-size='md'] .ic { width: 18px; height: 18px; }
  .btn[data-size='lg'] .ic { width: 20px; height: 20px; }

  .ic { display: inline-flex; align-items: center; }
  .ic :global(svg) { width: 100%; height: 100%; }

  /* variants */
  .btn[data-variant='primary'] {
    background: var(--color-accent);
    color: var(--color-on-accent);
    box-shadow: var(--shadow-accent);
  }
  .btn[data-variant='primary']:not(:disabled):not([aria-disabled='true']):hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }
  .btn[data-variant='primary']:not(:disabled):not([aria-disabled='true']):active {
    background: var(--color-accent-active);
    transform: translateY(0);
  }

  .btn[data-variant='secondary'] {
    background: var(--ecoteq-navy);
    color: var(--ecoteq-white);
  }
  .btn[data-variant='secondary']:not(:disabled):not([aria-disabled='true']):hover {
    background: var(--navy-600);
  }

  .btn[data-variant='ghost'] {
    background: transparent;
    color: var(--ecoteq-navy);
  }
  .btn[data-variant='ghost']:not(:disabled):not([aria-disabled='true']):hover {
    background: var(--color-accent-tint);
    color: var(--color-accent-active);
  }

  .btn[data-variant='outline-light'] {
    background: transparent;
    color: var(--ecoteq-white);
    border-color: rgba(255, 255, 255, 0.55);
  }
  .btn[data-variant='outline-light']:not(:disabled):not([aria-disabled='true']):hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  @media (prefers-reduced-motion: reduce) {
    .btn { transition: none; }
    .btn:hover { transform: none !important; }
  }
</style>
