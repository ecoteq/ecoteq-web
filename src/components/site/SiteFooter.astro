---
import Logo from '../brand/Logo.astro';
import Icon from '../Icon.astro';
import { CONTACT, TECHNOLOGIES, SOLUTIONS, SPOKES, quoteHref } from '../../lib/site';

const company = [
  { label: 'Rólunk', href: '/rolunk/' },
  { label: 'Referenciák', href: '/referenciak/' },
  { label: 'Szerviz és alkatrész', href: '/szerviz-es-alkatresz/' },
  { label: 'Tudástár', href: '/tudastar/' },
  { label: 'Kapcsolat', href: '/kapcsolat/' },
  { label: 'Ajánlatkérés', href: quoteHref(undefined, 'footer') },
];
const legal = [
  { label: 'Adatvédelmi tájékoztató', href: '/adatvedelmi-tajekoztato/' },
  { label: 'Cookie-tájékoztató', href: '/cookie-tajekoztato/' },
  { label: 'Felhasználási feltételek', href: '/felhasznalasi-feltetelek/' },
  { label: 'Impresszum', href: '/impresszum/' },
];
const year = 2026;
---

<footer class="footer" id="kapcsolat">
  <div class="inner">
    <nav class="cols" aria-label="Lábléc navigáció">
      <div class="col">
        <h3>Megoldások</h3>
        <ul>{SOLUTIONS.map((s) => <li><a href={s.href}>{s.label}</a></li>)}</ul>
      </div>
      <div class="col">
        <h3>Technológiák</h3>
        <ul>{TECHNOLOGIES.map((t) => <li><a href={`/technologiak/${t.slug}/`}>{t.name}</a></li>)}</ul>
      </div>
      <div class="col">
        <h3>ECOTEQ</h3>
        <ul>{company.map((c) => <li><a href={c.href}>{c.label}</a></li>)}</ul>
      </div>
      <div class="col">
        <h3>Kapcsolódó oldalak</h3>
        <ul>{SPOKES.map((s) => (
          <li>
            <a class="spoke" href={s.href} target="_blank" rel="noopener">
              <span class="spoke-host">{s.label}<Icon name="arrow-up-right" size={14} /></span>
              <span class="spoke-note">{s.note}</span>
            </a>
          </li>
        ))}</ul>
      </div>
      <div class="col">
        <h3>Kapcsolat</h3>
        <address class="contact">
          <span>{CONTACT.company}</span>
          <span>{CONTACT.address}</span>
          <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
          <a href={CONTACT.phoneHref}>{CONTACT.phone}</a>
        </address>
      </div>
    </nav>

    <div class="bottom">
      <Logo tone="white" size={22} />
      <nav class="legal" aria-label="Jogi">
        {legal.map((l, i) => (
          <>
            {i > 0 && <span class="sep" aria-hidden="true">|</span>}
            <a href={l.href}>{l.label}</a>
          </>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--navy-900); color: rgba(255, 255, 255, 0.72); }
  /* Dark mode: match the side rail's deep band instead of the lighter navy. */
  :global(html[data-mode='dark']) .footer { background: var(--color-surface-dark); }
  .inner { max-width: var(--container-max); margin-inline: auto; padding: var(--space-9) clamp(16px, 4vw, 40px) var(--space-7); }

  .cols { display: grid; gap: var(--space-8) var(--space-5); grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 680px) { .cols { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .cols { grid-template-columns: repeat(5, 1fr); } }

  .col h3 {
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: var(--fw-bold);
    color: var(--ecoteq-white);
    margin: 0 0 var(--space-5);
  }
  .col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: calc(var(--space-4) / 2); }
  .col li { line-height: 1.1; }
  .col a, .contact a { color: rgba(255, 255, 255, 0.72); text-decoration: none; font-size: var(--fs-sm); line-height: 1.1; transition: color var(--dur-fast) var(--ease-standard); }
  .col a:hover, .contact a:hover { color: var(--color-accent); }

  .contact { font-style: normal; display: flex; flex-direction: column; gap: var(--space-3); font-size: var(--fs-sm); line-height: var(--lh-snug); }
  .contact span { color: rgba(255, 255, 255, 0.72); }

  .spoke { display: inline-flex; flex-direction: column; gap: 2px; }
  .spoke-host { display: inline-flex; align-items: center; gap: 7px; }
  .spoke-host :global(.icon) { color: rgba(255, 255, 255, 0.4); flex: none; transition: color var(--dur-fast) var(--ease-standard); }
  .spoke:hover .spoke-host :global(.icon) { color: var(--color-accent); }
  .spoke-note { font-size: var(--fs-xs); color: rgba(255, 255, 255, 0.46); }

  .bottom {
    margin-top: var(--space-6);
    padding-top: var(--space-3);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4) var(--space-7);
  }
  .bottom :global(.logo) { flex: none; }

  .legal { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2) var(--space-4); }
  .legal a { color: rgba(255, 255, 255, 0.6); text-decoration: none; font-size: var(--fs-sm); transition: color var(--dur-fast) var(--ease-standard); }
  .legal a:hover { color: var(--color-accent); }
  .legal .sep { color: var(--ecoteq-green); }

  @media (prefers-reduced-motion: reduce) {
    .col a, .contact a, .legal a { transition: none; }
  }
</style>
