---
import SiteLayout from '../layouts/SiteLayout.astro';
import Hero from '../components/site/Hero.astro';
import SectionHeading from '../components/brand/SectionHeading.astro';
---

<SiteLayout
  title="Ipari hulladék- és biomassza-feldolgozó rendszerek"
  description="Az ECOTEQ ipari darálási, szárítási, brikettálási, pelletálási, elszívási és anyagmozgatási rendszerekben segít magyarországi és közép-európai üzemeknek."
>
  <Hero />

  <!-- Slice B sections land here: technology gateways, problem-based entry,
       systems-thinking, references, manufacturers, process, why-ECOTEQ, knowledge,
       pre-qualification form, closing CTA. -->
  <section id="technologiak" class="soon">
    <div class="wrap">
      <SectionHeading
        overline="Épül"
        title="A főoldal következő szekciói hamarosan érkeznek."
        lead="A keret (bal brand rail, felső navigáció, lábléc) és a hero készen van. A következő körben jönnek a technológiai kapuk, a probléma-alapú belépő, a rendszerszemlélet és a többi szekció."
      />
    </div>
  </section>
</SiteLayout>

<style>
  .soon { padding: var(--space-10) clamp(16px, 4vw, 40px); background: var(--color-bg-subtle); }
  .wrap { max-width: var(--container-max); margin-inline: auto; }
</style>
