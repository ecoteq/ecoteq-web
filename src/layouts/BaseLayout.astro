---
import '../ds/styles.css';
import fustatLatin from '../ds/assets/fonts/fustat-latin.woff2?url';
import fustatExt from '../ds/assets/fonts/fustat-ext.woff2?url';
import { ALLOW_INDEXING, SITE_NAME, GA_ID } from '../config';
import Schema from '../components/seo/Schema.astro';

interface Props {
  title: string;
  description?: string;
  /** Sub-brand key (e.g. "brikettalo") -> sets data-brand for re-skinning. */
  brand?: string;
  /** Optional LCP hero image base (e.g. "/heroes/hero-home") → emits a responsive
   *  <link rel=preload as=image>. Pages with an above-the-fold hero pass this. */
  heroImage?: string;
  /** Per-page noindex (utility/conversion pages, pl. /koszonjuk/). */
  noindex?: boolean;
}

const { title, description, brand, heroImage, noindex } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://ecoteq.hu').toString();
const ogImage = new URL('/og.jpg', Astro.site ?? 'https://ecoteq.hu').toString();
---

<!doctype html>
<html lang="hu" data-brand={brand}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {SITE_NAME}</title>
    {description && <meta name="description" content={description} />}
    {(!ALLOW_INDEXING || noindex) && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/ds/logo-mark-green.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1c3449" media="(prefers-color-scheme: dark)" />
    {/* Brand font preload (latin + extended — Hungarian ő/ű) to avoid FOUT/CLS on the H1. */}
    <link rel="preload" as="font" type="font/woff2" href={fustatLatin} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={fustatExt} crossorigin />
    {/* LCP hero image preload (responsive) — only when the page declares a hero. */}
    {heroImage && (
      <link
        rel="preload"
        as="image"
        type="image/webp"
        imagesrcset={`${heroImage}-640.webp 640w, ${heroImage}-1280.webp 1280w, ${heroImage}-1920.webp 1920w`}
        imagesizes="100vw"
        fetchpriority="high"
      />
    )}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="hu_HU" />
    <meta property="og:title" content={`${title} · ${SITE_NAME}`} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="ECOTEQ — ipari hulladékból kezelhető anyag" />
    <meta name="twitter:card" content="summary_large_image" />
    <Schema org webpage={{ title, description }} />
    {/* GA4 with Consent Mode v2 — analytics denied by default; granted only after
        the visitor accepts the cookie banner (choice persisted in localStorage). */}
    {GA_ID && (
      <>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}window.gtag=gtag;gtag('consent','default',{ad_storage:'denied',ad_user_data:'denied',ad_personalization:'denied',analytics_storage:'denied',wait_for_update:500});try{if(localStorage.getItem('cookie-consent')==='granted'){gtag('consent','update',{analytics_storage:'granted'})}}catch(e){}gtag('js',new Date());gtag('config','${GA_ID}',{anonymize_ip:true});`} />
        {/* gtag.js betöltése a load után / első interakcióra — kikerül az LCP-ablakból.
            A dataLayer addig sorba gyűjt, így nincs mérési veszteség. */}
        <script is:inline set:html={`(function(){var l=false;function g(){if(l)return;l=true;var s=document.createElement('script');s.async=true;s.src='https://www.googletagmanager.com/gtag/js?id=${GA_ID}';document.head.appendChild(s)}if(document.readyState==='complete'){setTimeout(g,1500)}else{addEventListener('load',function(){setTimeout(g,1500)})}['pointerdown','keydown','scroll','touchstart'].forEach(function(e){addEventListener(e,g,{once:true,passive:true})})})();`} />
      </>
    )}
    {/* Theme: follow the OS setting by default; honour an explicit choice once made.
        Runs before paint to avoid a flash. Exposes window.__setTheme for the toggle. */}
    <script is:inline>
      (function () {
        var d = document.documentElement;
        var mq = window.matchMedia('(prefers-color-scheme: dark)');
        function stored() { try { return localStorage.getItem('theme'); } catch (e) { return null; } }
        function apply(mode) { d.dataset.mode = mode; d.style.colorScheme = mode; }
        apply(stored() || (mq.matches ? 'dark' : 'light'));
        window.__setTheme = function (mode) {
          try { localStorage.setItem('theme', mode); } catch (e) {}
          apply(mode);
        };
        mq.addEventListener('change', function (e) { if (!stored()) apply(e.matches ? 'dark' : 'light'); });
      })();
    </script>
    {/* Opt into scroll-reveal only when JS runs and motion is allowed (progressive enhancement). */}
    <script is:inline>
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        document.documentElement.classList.add('js-reveal');
      }
    </script>
  </head>
  <body>
    <slot />

    {/* Inline (never bundled, so it cannot fail to load) + a failsafe timeout:
        content is NEVER left stuck at opacity:0. */}
    <script is:inline>
      (function () {
        var els = document.querySelectorAll('[data-reveal]');
        if (!els.length) return;
        var root = document.documentElement;
        function revealAll() { els.forEach(function (el) { el.classList.add('is-visible'); }); }
        if (!root.classList.contains('js-reveal') || !('IntersectionObserver' in window)) {
          revealAll();
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
        );
        els.forEach(function (el) { io.observe(el); });
        // Failsafe: if anything misfires, reveal everything after 2.5s.
        setTimeout(revealAll, 2500);
      })();
    </script>

    {GA_ID && (
      <>
        <div class="cookie-consent" id="cookie-consent" role="dialog" aria-label="Cookie-hozzájárulás" hidden>
          <p class="cc-text">Ez a weboldal a forgalom méréséhez sütiket használ (Google Analytics), kizárólag az Ön hozzájárulásával. Részletek a <a href="/cookie-tajekoztato/">cookie-tájékoztatóban</a>.</p>
          <div class="cc-actions">
            <button type="button" class="cc-btn cc-reject" data-cc="denied">Elutasítom</button>
            <button type="button" class="cc-btn cc-accept" data-cc="granted">Elfogadom</button>
          </div>
        </div>
        <script is:inline>
          (function () {
            var el = document.getElementById('cookie-consent');
            if (!el) return;
            var stored = null;
            try { stored = localStorage.getItem('cookie-consent'); } catch (e) {}
            if (!stored) el.hidden = false;
            el.addEventListener('click', function (e) {
              var b = e.target.closest('[data-cc]');
              if (!b) return;
              var v = b.getAttribute('data-cc');
              try { localStorage.setItem('cookie-consent', v); } catch (e) {}
              if (v === 'granted' && window.gtag) gtag('consent', 'update', { analytics_storage: 'granted' });
              el.hidden = true;
            });
          })();
        </script>
      </>
    )}

    {GA_ID && (
      <script is:inline>
        document.addEventListener('click', function (e) {
          var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
          if (!a || typeof window.gtag !== 'function') return;
          var href = a.getAttribute('href') || '';
          if (href.indexOf('/ajanlatkeres') === -1 && href.indexOf('#ajanlatkeres') === -1) return;
          var loc = a.getAttribute('data-cta') || '';
          var tech = '';
          try { var u = new URL(href, location.origin); if (!loc) loc = u.searchParams.get('source') || ''; tech = u.searchParams.get('tech') || ''; } catch (err) {}
          var p = { cta_location: (loc || 'egyeb').slice(0, 100), cta_text: (a.textContent || '').replace(/\s+/g, ' ').trim().slice(0, 100), link_url: href.slice(0, 100), transport_type: 'beacon' };
          if (tech) p.technologia = tech.slice(0, 100);
          gtag('event', 'cta_click', p);
        }, true);
      </script>
    )}

    <style is:global>
      /* App-level radius reduction (DS tokens stay untouched): squarer cards + CTAs globally. */
      :root { --radius-lg: 8px; }

      /* Cookie consent banner (GA4 Consent Mode v2). */
      .cookie-consent { position: fixed; left: 50%; bottom: clamp(12px, 3vw, 24px); transform: translateX(-50%); z-index: 80; width: min(680px, calc(100vw - 24px)); display: flex; flex-wrap: wrap; align-items: center; gap: 12px 16px; padding: 14px 18px; background: var(--ecoteq-navy); color: #fff; border: 1px solid rgba(255,255,255,0.16); border-radius: var(--radius-lg); box-shadow: var(--shadow-md); }
      .cookie-consent[hidden] { display: none; }
      .cookie-consent .cc-text { margin: 0; flex: 1 1 280px; font-size: var(--fs-sm); line-height: var(--lh-snug); color: rgba(255,255,255,0.9); }
      .cookie-consent .cc-text a { color: #fff; text-decoration: underline; }
      .cookie-consent .cc-actions { display: flex; gap: 8px; flex: none; }
      .cookie-consent .cc-btn { font: inherit; font-size: var(--fs-sm); font-weight: var(--fw-bold); padding: 8px 16px; border-radius: var(--radius-md); cursor: pointer; border: 1px solid transparent; }
      .cookie-consent .cc-accept { background: var(--color-cta); color: #fff; }
      .cookie-consent .cc-accept:hover { background: var(--color-cta-hover); }
      .cookie-consent .cc-reject { background: transparent; color: #fff; border-color: rgba(255,255,255,0.4); }
      .cookie-consent .cc-reject:hover { background: rgba(255,255,255,0.1); }

      /* Balanced headings + tidy paragraphs: prevents lonely orphan words and
         disproportionate line breaks in text blocks (low specificity so components win). */
      :where(h1, h2, h3, h4) { text-wrap: balance; }
      :where(p, li, .lead) { text-wrap: pretty; }

      /* Form fields: a dedicated input surface/border. Light keeps the current look;
         dark gives inputs a raised fill + a clearly visible border (WCAG 1.4.11) and a
         brighter danger red so error text stays legible on the dark canvas. */
      :root { --color-input-bg: var(--color-bg-subtle); --color-input-border: var(--color-border); }
      html[data-mode="dark"] {
        --color-input-bg: var(--color-surface-alt);
        --color-input-border: #6b757d;
        --color-danger: #f87171;
      }

      /* The deepest band — shared by the brand rail and the footer so they read as
         one continuous dark frame. Darkest value the DS offers in each theme:
         navy-900 in light, surface-dark ("deepest band / rail") in dark. */
      :root { --color-deep-band: var(--navy-900); }
      html[data-mode="dark"] { --color-deep-band: var(--color-surface-dark); }

      /* Brand-navy accent panels (closing CTA, spoke strips). In dark the bright
         brand navy glares as a blue lump, so panels collapse to a calm deep navy
         that keeps brand identity without shouting. */
      :root { --color-brand-panel: var(--ecoteq-navy); }
      html[data-mode="dark"] { --color-brand-panel: #15212e; }

      /* ONE brand green across the whole site — the accessible deeper tone. Button
         fills use --color-cta; the SAME green also becomes the accent (rules, icons,
         links, focus, the logo dot) by overriding the raw --ecoteq-green it all
         derives from. White-on-green clears WCAG AA (4.7:1, was 2.8:1). The CTA lift
         is a restrained directional shadow now, not a green glow. */
      :root {
        --color-cta: #2b8437;
        --color-cta-hover: #25702f;
        --color-cta-active: #1f5e28;
        --ecoteq-green: #2b8437;
      --color-accent-on-dark: #54c35e;
        --color-accent-hover: #25702f;
        --color-accent-active: #1f5e28;
        --color-accent-ring: rgba(43, 132, 55, 0.24);
        --shadow-accent: 0 1px 2px rgba(28, 52, 73, 0.12), 0 7px 18px -5px rgba(43, 132, 55, 0.40);
      }

      /* WCAG AA contrast fixes (app-level, DS untouched):
         - muted text was #8a8a8a (~2.6:1 on white) → gray-600 #6c6c6e (~4.8:1);
         - in dark mode the accent-text token resolved to the deep green (~3.2:1) →
           route it to the lighter on-dark green so small green text/labels pass AA. */
      :root { --color-text-muted: var(--gray-600); }
      html[data-mode="dark"] { --color-accent-text: var(--color-accent-on-dark); }

      /* Quiet, premium scroll-reveal. Content is fully visible without JS / with reduced motion. */
      html.js-reveal [data-reveal] {
        opacity: 0;
        transform: translateY(16px);
        transition: opacity 620ms var(--ease-out), transform 620ms var(--ease-out);
      }
      html.js-reveal [data-reveal].is-visible {
        opacity: 1;
        transform: none;
      }

      /* Breadcrumbs (site-wide rule): UPPERCASE labels, bold green pipe separators. */
      .crumb { text-transform: uppercase; letter-spacing: 0.05em; }
      .crumb span[aria-hidden="true"] { color: var(--color-accent); font-weight: var(--fw-bold); }

      /* Consistent, accessible focus ring across interactive elements. */
      a:focus-visible,
      button:focus-visible,
      input:focus-visible,
      select:focus-visible,
      textarea:focus-visible,
      summary:focus-visible,
      [tabindex]:focus-visible {
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
      }

      /* Consistent, premium card polish across the site. The .shell prefix keeps
         this winning over component-scoped rules; inner micro-interactions
         (image zoom, arrow nudge) stay intact. */
      .shell main .card,
      .shell main .pcard,
      .shell main .rel,
      .shell main .scard,
      .shell main .tcard,
      .shell main .path,
      .shell main .ref {
        box-shadow: var(--shadow-xs);
        transition:
          transform var(--dur-base) var(--ease-out),
          box-shadow var(--dur-base) var(--ease-out),
          border-color var(--dur-base) var(--ease-out);
      }
      @media (hover: hover) {
        .shell main .card:hover,
        .shell main .pcard:hover,
        .shell main .rel:hover,
        .shell main .scard:hover,
        .shell main .tcard:hover,
        .shell main .path:hover,
        .shell main .ref:hover {
          box-shadow: 0 6px 16px -6px rgba(28, 52, 73, 0.12);
        }
      }
      @media (hover: hover) and (prefers-reduced-motion: no-preference) {
        .shell main .card:hover,
        .shell main .pcard:hover,
        .shell main .rel:hover,
        .shell main .scard:hover,
        .shell main .tcard:hover,
        .shell main .path:hover,
        .shell main .ref:hover {
          transform: scale(1.012);
        }
      }
    </style>
  </body>
</html>
