---
import Logo from '../brand/Logo.astro';
import Button from '../core/Button.astro';
import Icon from '../Icon.astro';
import { NAV, CTA, SOLUTIONS, TECHNOLOGIES } from '../../lib/site';

/**
 * Top sticky header — the real navigation, with Megoldások + Technológiák mega-menus.
 * Transparent over a dark hero, solid on scroll; pass `solid` on content pages without a
 * dark hero. Below 1024px: logo + hamburger drawer with accordions for the mega items.
 */
interface Props {
  solid?: boolean;
}
const { solid = false } = Astro.props;

const TECH_ICONS: Record<string, string> = {
  'ipari-daralas': 'shrink',
  'brikettalas': 'package',
  'pelletalas': 'boxes',
  'biomassza-szaritas': 'droplets',
  'vakuumszaritas': 'thermometer',
  'vakuumimpregnalas': 'shield',
  'elszivas-porlevalasztas': 'wind',
  'anyagmozgas-rendszerelemek': 'route',
};
---

<header class="site-header" id="site-header" data-transparent={solid ? undefined : ''} data-solid={solid ? '' : undefined}>
  <div class="bar">
    <a class="brand" href="/" aria-label="ECOTEQ – Kezdőlap">
      <Logo tone="white" size={24} class="brand-light" />
      <Logo tone="navy" size={24} class="brand-dark" />
    </a>

    <nav class="nav" aria-label="Fő navigáció">
      <ul>
        {NAV.map((i) =>
          i.mega ? (
            <li class="has-mega">
              <button class="nav-trigger" type="button" aria-expanded="false" aria-haspopup="true">
                {i.label}<Icon name="chevron-down" size={15} class="caret" />
              </button>
              <div class="mega">
                <div class="mega-inner">
                  {i.mega === 'solutions' && (
                    <>
                      <div class="mega-head">
                        <p class="mega-title">Megoldások üzemi feladatra</p>
                        <p class="mega-sub">Válasszon abból kiindulva, milyen anyaggal vagy üzemi problémával dolgozik.</p>
                      </div>
                      <ul class="mega-grid sol">
                        {SOLUTIONS.map((s) => (
                          <li>
                            <a href={s.href}>
                              <span class="m-top"><span class="m-label">{s.label}</span><Icon name="arrow-right" size={15} class="m-arrow" /></span>
                              <span class="m-blurb">{s.blurb}</span>
                              {s.tech.length > 0 && <span class="m-chips">{s.tech.map((c) => <span class="chip">{c}</span>)}</span>}
                            </a>
                          </li>
                        ))}
                      </ul>
                    </>
                  )}
                  {i.mega === 'technologies' && (
                    <>
                      <div class="mega-head">
                        <p class="mega-title">Technológiai területek</p>
                        <p class="mega-sub">Ha már tudja, melyik technológiai irány érdekli, innen induljon.</p>
                      </div>
                      <ul class="mega-grid tech">
                        {TECHNOLOGIES.map((t) => (
                          <li>
                            <a href={`/technologiak/${t.slug}/`}>
                              <span class="m-ic"><Icon name={TECH_ICONS[t.slug] ?? 'settings'} size={20} /></span>
                              <span class="m-top"><span class="m-label">{t.name}</span><Icon name="arrow-right" size={15} class="m-arrow" /></span>
                              <span class="m-blurb">{t.blurb}</span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </>
                  )}
                </div>
              </div>
            </li>
          ) : (
            <li><a href={i.href}>{i.label}</a></li>
          )
        )}
      </ul>
    </nav>

    <div class="actions">
      <Button href={CTA.primary.href} size="sm" class="header-cta">{CTA.primary.label}</Button>
      <button class="burger" type="button" aria-label="Menü megnyitása" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="mobile" id="mobile-menu" hidden>
    <ul>
      {NAV.map((i) =>
        i.mega ? (
          <li>
            <button class="m-acc" type="button" aria-expanded="false">{i.label}<Icon name="chevron-down" size={18} /></button>
            <div class="m-sub" hidden>
              {(i.mega === 'solutions'
                ? SOLUTIONS.map((s) => ({ label: s.label, href: s.href }))
                : TECHNOLOGIES.map((t) => ({ label: t.name, href: `/technologiak/${t.slug}/` }))
              ).map((x) => <a href={x.href}>{x.label}</a>)}
            </div>
          </li>
        ) : (
          <li><a href={i.href}>{i.label}</a></li>
        )
      )}
    </ul>
    <Button href={CTA.primary.href} class="mobile-cta">{CTA.primary.label}</Button>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  if (header) {
    const burger = header.querySelector<HTMLButtonElement>('.burger');
    const menu = document.getElementById('mobile-menu');

    if (!header.hasAttribute('data-solid')) {
      const onScroll = () => {
        if (window.scrollY > 24) header.removeAttribute('data-transparent');
        else header.setAttribute('data-transparent', '');
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    const closeMenu = () => {
      header.removeAttribute('data-open');
      burger?.setAttribute('aria-expanded', 'false');
      if (menu) menu.hidden = true;
    };
    burger?.addEventListener('click', () => {
      const open = header.toggleAttribute('data-open');
      burger.setAttribute('aria-expanded', String(open));
      if (menu) menu.hidden = !open;
    });
    menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));

    // Mobile accordions
    header.querySelectorAll<HTMLButtonElement>('.m-acc').forEach((b) => {
      b.addEventListener('click', () => {
        const sub = b.nextElementSibling as HTMLElement | null;
        const open = b.getAttribute('aria-expanded') === 'true';
        b.setAttribute('aria-expanded', String(!open));
        if (sub) sub.hidden = open;
      });
    });

    // Desktop mega: click (touch) toggles, Escape / outside-click closes
    const megas = Array.from(header.querySelectorAll<HTMLElement>('.has-mega'));
    megas.forEach((li) => {
      const trigger = li.querySelector<HTMLButtonElement>('.nav-trigger');
      trigger?.addEventListener('click', (e) => {
        e.preventDefault();
        const isOpen = li.classList.contains('is-open');
        megas.forEach((x) => { x.classList.remove('is-open'); x.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false'); });
        if (!isOpen) { li.classList.add('is-open'); trigger.setAttribute('aria-expanded', 'true'); }
      });
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') megas.forEach((x) => { x.classList.remove('is-open'); x.querySelector('.nav-trigger')?.setAttribute('aria-expanded', 'false'); });
    });
    document.addEventListener('click', (e) => {
      if (!header.contains(e.target as Node)) megas.forEach((x) => x.classList.remove('is-open'));
    });
  }
</script>

<style>
  .site-header {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 50;
    background: var(--ecoteq-white);
    border-bottom: 1px solid var(--color-border);
    transition: background var(--dur-base) var(--ease-standard), border-color var(--dur-base) var(--ease-standard), box-shadow var(--dur-base) var(--ease-standard);
  }
  @media (min-width: 1024px) { .site-header { left: var(--sidebar-w); } }

  .site-header[data-transparent] { background: transparent; border-color: transparent; box-shadow: none; }
  .site-header:not([data-transparent]) { box-shadow: var(--shadow-sm); }

  .bar {
    height: var(--header-h);
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: clamp(16px, 4vw, 40px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .brand { display: inline-flex; flex: none; }
  .site-header[data-transparent] .brand-light { display: inline-flex; }
  .site-header[data-transparent] .brand-dark { display: none; }
  .site-header:not([data-transparent]) .brand-light { display: none; }
  .site-header:not([data-transparent]) .brand-dark { display: inline-flex; }

  .nav { display: none; }
  @media (min-width: 1024px) {
    .nav { display: block; margin-left: auto; }
    .nav > ul { display: flex; gap: 24px; list-style: none; margin: 0; padding: 0; align-items: center; }
    .nav a, .nav-trigger {
      font-family: var(--font-sans);
      font-size: var(--fs-sm);
      font-weight: var(--fw-semibold);
      color: var(--ecoteq-navy);
      text-decoration: none;
      transition: color var(--dur-fast) var(--ease-standard);
    }
    .nav a:hover, .nav-trigger:hover { color: var(--color-accent); }
  }

  .has-mega { position: static; }
  .nav-trigger { display: inline-flex; align-items: center; gap: 5px; background: none; border: none; padding: 0; cursor: pointer; }
  .caret { transition: transform var(--dur-fast) var(--ease-standard); }
  .has-mega:hover .caret, .has-mega.is-open .caret { transform: rotate(180deg); }

  .mega {
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    background: var(--color-surface);
    border-top: 2px solid var(--color-accent);
    box-shadow: var(--shadow-lg);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);
    transition: opacity var(--dur-base) var(--ease-standard), transform var(--dur-base) var(--ease-standard), visibility var(--dur-base);
  }
  .has-mega:hover > .mega, .has-mega:focus-within > .mega, .has-mega.is-open > .mega { opacity: 1; visibility: visible; transform: none; }

  .mega-inner { max-width: var(--container-max); margin-inline: auto; padding: var(--space-6) clamp(16px, 4vw, 40px) var(--space-7); }
  .mega-head { margin-bottom: var(--space-5); }
  .mega-title { margin: 0 0 4px; font-family: var(--font-display); font-weight: var(--fw-extrabold); font-size: var(--fs-h4); color: var(--color-text); letter-spacing: var(--ls-heading); }
  .mega-sub { margin: 0; font-size: var(--fs-sm); color: var(--color-text-secondary); }

  .mega-grid { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-2); }
  .mega-grid.sol { grid-template-columns: repeat(2, 1fr); }
  .mega-grid.tech { grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 1280px) { .mega-grid.sol { grid-template-columns: repeat(4, 1fr); } .mega-grid.tech { grid-template-columns: repeat(4, 1fr); } }

  .mega-grid a { display: flex; flex-direction: column; gap: 5px; padding: var(--space-4); border-radius: var(--radius-md); border: 1px solid transparent; text-decoration: none; color: var(--color-text); transition: background var(--dur-fast) var(--ease-standard), border-color var(--dur-fast) var(--ease-standard); }
  .mega-grid a:hover { background: var(--color-bg-subtle); border-color: var(--color-border); }
  .m-ic { color: var(--color-accent); display: inline-flex; margin-bottom: 2px; }
  .m-top { display: inline-flex; align-items: center; justify-content: space-between; gap: 8px; }
  .m-label { font-weight: var(--fw-bold); font-size: var(--fs-sm); color: var(--color-text); }
  .m-arrow { color: var(--color-accent); flex: none; opacity: 0; transform: translateX(-4px); transition: opacity var(--dur-fast), transform var(--dur-fast); }
  .mega-grid a:hover .m-arrow { opacity: 1; transform: none; }
  .m-blurb { font-size: var(--fs-xs); color: var(--color-text-secondary); line-height: var(--lh-snug); }
  .m-chips { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 4px; }
  .chip { font-size: 10px; font-weight: var(--fw-semibold); color: var(--green-700); background: var(--color-accent-tint); border-radius: var(--radius-pill); padding: 3px 9px; }

  .actions { display: flex; align-items: center; gap: 12px; }
  .header-cta { display: none; }
  @media (min-width: 1024px) { .header-cta { display: inline-flex; } }

  .site-header[data-transparent] .nav a,
  .site-header[data-transparent] .nav-trigger,
  .site-header[data-transparent] .burger span { color: var(--ecoteq-white); }
  .site-header[data-transparent] .burger span { background: var(--ecoteq-white); }

  .burger { display: inline-flex; flex-direction: column; justify-content: center; gap: 5px; width: 44px; height: 44px; padding: 10px; background: transparent; border: none; cursor: pointer; }
  .burger span { display: block; height: 2px; width: 100%; background: var(--ecoteq-navy); border-radius: 2px; transition: transform var(--dur-base) var(--ease-standard), opacity var(--dur-fast) var(--ease-standard); }
  @media (min-width: 1024px) { .burger { display: none; } }
  .site-header[data-open] .burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .site-header[data-open] .burger span:nth-child(2) { opacity: 0; }
  .site-header[data-open] .burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .mobile { background: var(--ecoteq-white); border-top: 1px solid var(--color-border); box-shadow: var(--shadow-md); padding: 10px clamp(16px, 4vw, 40px) 22px; max-height: calc(100vh - var(--header-h)); overflow-y: auto; }
  .mobile > ul { list-style: none; margin: 0 0 14px; padding: 0; display: flex; flex-direction: column; }
  .mobile > ul > li { border-bottom: 1px solid var(--color-border); }
  .mobile a, .m-acc { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 13px 4px; font-size: var(--fs-lg); font-weight: var(--fw-semibold); color: var(--ecoteq-navy); text-decoration: none; background: none; border: none; font-family: var(--font-sans); cursor: pointer; }
  .m-sub { display: flex; flex-direction: column; padding: 0 4px 10px 14px; }
  .m-sub a { font-size: var(--fs-body); font-weight: var(--fw-regular); color: var(--color-text-secondary); padding: 9px 0; border: none; }
  .mobile-cta { width: 100%; }
  @media (min-width: 1024px) { .mobile { display: none; } }

  @media (prefers-reduced-motion: reduce) {
    .site-header, .burger span, .mega, .caret, .m-arrow, .nav a, .nav-trigger { transition: none; }
  }
</style>
