---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kezdőlap" description="ECOTEQ — ipari hulladékfeldolgozó rendszerek kulcsrakészen.">
  <main style="max-width: var(--container-max); margin-inline: auto; padding: var(--space-9) var(--space-5);">
    <p class="eco-overline" style="color: var(--color-accent-text);">ECOTEQ · ÚJ WEBOLDAL</p>
    <h1>Ipari hulladékfeldolgozó rendszerek kulcsrakészen.</h1>
    <p style="font-size: var(--fs-lg); color: var(--color-text-secondary); max-width: 60ch;">
      Az új oldal építés alatt. A design system él — nézd meg a
      <a href="/styleguide">styleguide</a> oldalt a bizonyítékért.
    </p>
  </main>
</BaseLayout>
