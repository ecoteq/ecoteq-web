---
/** Reusable page hero — full-bleed image with the site's standard navy mask
    (same fade in light + dark, driven by --color-surface-dark) and a title block.
    Optional breadcrumb + a default slot for CTAs below the lead. */
import Overline from '../brand/Overline.astro';
import Breadcrumb from './Breadcrumb.astro';

interface CrumbItem { label: string; href?: string; }
interface Props {
  title: string;
  lead?: string;
  eyebrow?: string;
  image: string;
  imageAlt?: string;
  crumb?: CrumbItem[];
}
const { title, lead, eyebrow, image, imageAlt = '', crumb } = Astro.props;
---

<section class="phero">
  <div class="media">
    <img src={image} alt={imageAlt} fetchpriority="high" decoding="async" />
    <div class="wash" aria-hidden="true"></div>
  </div>

  <div class="inner">
    {eyebrow && <Overline class="eyebrow">{eyebrow}</Overline>}
    <h1>{title}</h1>
    {lead && <p class="lead">{lead}</p>}
    <div class="actions"><slot /></div>
  </div>
</section>

{crumb && crumb.length > 0 && <Breadcrumb items={crumb} />}

<style>
  .phero {
    position: relative;
    margin-top: calc(-1 * var(--header-h));
    min-height: 75vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--ecoteq-navy);
  }
  .media { position: absolute; inset: 0; z-index: 0; }
  .media img { width: 100%; height: 100%; object-fit: cover; }
  /* Same mask in both modes — the token resolves per theme (navy in light, near-black
     in dark): solid field on the left for the text, clearing to the image on the right. */
  .wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg,
        var(--color-surface-dark) 0%,
        var(--color-surface-dark) 46%,
        color-mix(in srgb, var(--color-surface-dark) 82%, transparent) 62%,
        color-mix(in srgb, var(--color-surface-dark) 32%, transparent) 82%,
        transparent 100%),
      linear-gradient(0deg,
        color-mix(in srgb, var(--color-surface-dark) 55%, transparent) 0%,
        transparent 48%);
  }

  .inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--container-max);
    margin-inline: auto;
    padding: calc(var(--header-h) + var(--space-7)) clamp(16px, 4vw, 40px) var(--space-7);
  }

  .eyebrow { color: var(--ecoteq-green); margin-bottom: var(--space-4); }

  h1 {
    color: var(--ecoteq-white);
    font-size: clamp(2rem, 1.2rem + 3vw, 3.4rem);
    line-height: var(--lh-tight);
    letter-spacing: var(--ls-display);
    max-width: 18ch;
    margin: 0 0 var(--space-4);
  }

  .lead {
    color: rgba(255, 255, 255, 0.86);
    font-size: var(--fs-lg);
    line-height: var(--lh-body);
    max-width: 56ch;
    margin: 0;
  }

  .actions:not(:empty) { margin-top: var(--space-6); display: flex; flex-wrap: wrap; gap: var(--space-4); }
</style>
