---
import Logo from '../brand/Logo.astro';
import Icon from '../Icon.astro';
import { CONTACT, quoteHref, SOCIAL } from '../../lib/site';

/**
 * Fixed left navy brand / utility rail — DESKTOP ONLY (≥1280px). A brand frame,
 * NOT navigation: home mark (home link), one restrained green pre-qualification
 * CTA, and quiet contact icons. No menu icons, no dashboard feel. Hidden on
 * tablet and mobile.
 */
const PREQUAL_HREF = quoteHref(undefined, 'rail');
---

<aside class="rail">
  <a class="rail-logo" href="/" aria-label="ECOTEQ – Kezdőlap">
    <Logo tone="white" size={34} showWordmark={false} />
  </a>

  <div class="rail-bottom">
    <a
      class="rail-cta"
      href={PREQUAL_HREF}
      aria-label="Leírom az anyagot és a célt"
      title="Leírom az anyagot és a célt"
    >Előminősítés</a>
    <div class="rail-social">
      {SOCIAL.map((s) => (
        <a href={s.href} target="_blank" rel="noopener" aria-label={`${s.label} – új lapon`} title={s.label}><Icon name={s.icon} size={16} /></a>
      ))}
    </div>
    <div class="rail-contact">
      <a href={`mailto:${CONTACT.email}`} aria-label="E-mail küldése" title={CONTACT.email}><Icon name="mail" size={16} /></a>
      <a href="https://wa.me/3614301556" target="_blank" rel="noopener" aria-label="WhatsApp üzenet" title="WhatsApp"><Icon name="whatsapp" size={16} /></a>
      <a href="viber://chat?number=%2B3614301556" aria-label="Viber üzenet" title="Viber"><Icon name="viber" size={16} /></a>
      <a href={CONTACT.phoneHref} aria-label="Telefonhívás" title={CONTACT.phone}><Icon name="phone" size={16} /></a>
    </div>
  </div>
</aside>

<style>
  .rail { display: none; }

  @media (min-width: 1280px) {
    .rail {
      position: fixed;
      inset: 0 auto 0 0;
      width: var(--sidebar-w);
      background: var(--color-deep-band);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: space-between;
      padding: 22px 0;
      z-index: 60;
    }
  }

  .rail-logo { display: inline-flex; border-radius: var(--radius-md); }

  /* Restrained green pre-qual tab — no glow, square-ish to match the site. */
  .rail-cta {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    background: var(--color-cta);
    color: var(--color-on-accent);
    font-weight: var(--fw-bold);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-overline);
    text-transform: uppercase;
    text-decoration: none;
    padding: 18px 10px;
    border-radius: var(--radius-md);
    transition: background var(--dur-base) var(--ease-standard);
  }
  .rail-cta:hover { background: var(--color-cta-hover); }

  .rail-bottom { display: flex; flex-direction: column; align-items: center; gap: 16px; }
  .rail-social, .rail-contact { display: flex; flex-direction: column; gap: 10px; }
  .rail-social a, .rail-contact a {
    width: 38px;
    height: 38px;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.32);
    color: var(--ecoteq-white);
    display: grid;
    place-items: center;
    transition: background var(--dur-base) var(--ease-standard), border-color var(--dur-base) var(--ease-standard);
  }
  .rail-social a:hover, .rail-contact a:hover { background: var(--color-cta); border-color: var(--color-cta); }

  @media (prefers-reduced-motion: reduce) {
    .rail-cta, .rail-contact a, .rail-social a { transition: none; }
  }
</style>
