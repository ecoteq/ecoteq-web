---
import Logo from '../brand/Logo.astro';
import Icon from '../Icon.astro';
import { CONTACT, TECHNOLOGIES, SPOKES, quoteHref } from '../../lib/site';

const solutions = [
  'Faipari hulladék kezelése',
  'Raklap és csomagolóanyag darálása',
  'Forgács és por hasznosítása',
  'Nedves biomassza előkészítése',
  'Faanyag szárítása és kezelése',
  'Komplett anyagáram-rendszerek',
];
const company = [
  { label: 'Rólunk', href: '/rolunk/' },
  { label: 'Referenciák', href: '/referenciak/' },
  { label: 'Szerviz és alkatrész', href: '/szerviz-es-alkatresz/' },
  { label: 'Tudástár', href: '/tudastar/' },
  { label: 'Kapcsolat', href: '/kapcsolat/' },
  { label: 'Ajánlatkérés', href: quoteHref(undefined, 'footer') },
];
const legal = [
  { label: 'Adatvédelmi tájékoztató', href: '/adatvedelmi-tajekoztato', icon: 'shield-check' },
  { label: 'Cookie-tájékoztató', href: '/cookie-tajekoztato', icon: 'cookie' },
  { label: 'Felhasználási feltételek', href: '/felhasznalasi-feltetelek', icon: 'file-text' },
  { label: 'Impresszum', href: '/impresszum', icon: 'info' },
];
const year = 2026;
---

<footer class="footer" id="kapcsolat">
  <div class="inner">
    <div class="top">
      <div class="brand-col">
        <Logo tone="white" size={30} />
        <p class="about">
          Ipari hulladék- és biomassza-feldolgozó rendszerek magyarországi és
          közép-európai üzemeknek.
        </p>
        <nav class="brand-nav" aria-label="ECOTEQ">
          {company.map((c) => <a href={c.href}>{c.label}</a>)}
        </nav>
      </div>

      <nav class="cols" aria-label="Lábléc navigáció">
        <div class="col">
          <h3>Megoldások</h3>
          <ul>{solutions.map((s) => <li><a href="#megoldasok">{s}</a></li>)}</ul>
        </div>
        <div class="col">
          <h3>Technológiák</h3>
          <ul>{TECHNOLOGIES.map((t) => <li><a href={`/technologiak/${t.slug}/`}>{t.name}</a></li>)}</ul>
        </div>
        <div class="col">
          <h3>Kapcsolódó oldalak</h3>
          <ul>{SPOKES.map((s) => (
            <li>
              <a class="spoke" href={s.href} target="_blank" rel="noopener">
                <span class="spoke-host">{s.label}<Icon name="arrow-up-right" size={14} /></span>
                <span class="spoke-note">{s.note}</span>
              </a>
            </li>
          ))}</ul>
        </div>
      </nav>
    </div>

    <div class="bottom">
      <span>© {year} {CONTACT.company} Minden jog fenntartva.</span>
      <nav class="legal" aria-label="Jogi">
        {legal.map((l, i) => (
          <>
            {i > 0 && <span class="sep" aria-hidden="true">|</span>}
            <a href={l.href}>{l.label}</a>
          </>
        ))}
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--navy-900); color: rgba(255, 255, 255, 0.78); }
  .inner { max-width: var(--container-max); margin-inline: auto; padding: var(--space-9) clamp(16px, 4vw, 40px) var(--space-6); }

  .top { display: grid; gap: var(--space-7); grid-template-columns: 1fr; }
  @media (min-width: 768px) { .top { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1080px) { .top { grid-template-columns: 1.2fr 2.8fr; gap: var(--space-8); } }

  .about { font-size: var(--fs-sm); line-height: var(--lh-body); margin: var(--space-4) 0 var(--space-5); max-width: 42ch; }

  .brand-nav { display: flex; flex-direction: column; gap: 10px; margin-top: var(--space-2); }
  .brand-nav a { color: rgba(255, 255, 255, 0.78); text-decoration: none; font-size: var(--fs-sm); transition: color var(--dur-fast) var(--ease-standard); }
  .brand-nav a:hover { color: var(--color-accent); }

  .cols { display: grid; gap: var(--space-6) var(--space-5); grid-template-columns: repeat(2, 1fr); }
  @media (min-width: 680px) { .cols { grid-template-columns: repeat(3, 1fr); } }

  .col h3 {
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    font-weight: var(--fw-bold);
    letter-spacing: var(--ls-overline);
    text-transform: uppercase;
    color: var(--ecoteq-white);
    margin: 0 0 var(--space-4);
  }
  .col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .col a, address a { color: rgba(255, 255, 255, 0.78); text-decoration: none; font-size: var(--fs-sm); transition: color var(--dur-fast) var(--ease-standard); }
  .col a:hover, address a:hover { color: var(--color-accent); }

  address { font-style: normal; display: flex; flex-direction: column; gap: 8px; font-size: var(--fs-sm); }
  address span { color: rgba(255, 255, 255, 0.78); }
  .contact { margin-top: var(--space-5); }

  .spoke { display: inline-flex; flex-direction: column; gap: 2px; }
  .spoke-host { display: inline-flex; align-items: center; gap: 7px; }
  .spoke-host :global(.icon) { color: rgba(255, 255, 255, 0.42); flex: none; transition: color var(--dur-fast) var(--ease-standard); }
  .spoke:hover .spoke-host :global(.icon) { color: var(--color-accent); }
  .spoke-note { font-size: var(--fs-xs); color: rgba(255, 255, 255, 0.5); }

  .ic-link { display: inline-flex; align-items: center; gap: 9px; }
  .ic-link :global(.icon) { color: rgba(255, 255, 255, 0.42); flex: none; transition: color var(--dur-fast) var(--ease-standard); }
  .ic-link:hover :global(.icon) { color: var(--color-accent); }

  .bottom {
    margin-top: var(--space-7);
    padding-top: var(--space-5);
    border-top: 1px solid rgba(255, 255, 255, 0.14);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: space-between;
    font-size: var(--fs-xs);
    color: var(--color-text-muted);
  }
  .legal { display: flex; flex-wrap: wrap; align-items: center; gap: 6px; }
  .legal a { color: var(--color-text-muted); text-decoration: none; }
  .legal a:hover { color: var(--color-accent); }
  .legal .sep { color: var(--ecoteq-green); }

  @media (prefers-reduced-motion: reduce) { .col a, address a { transition: none; } }
</style>
