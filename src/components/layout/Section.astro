---
/** Consistent section wrapper — vertical rhythm + container + surface alternation. */
interface Props {
  id?: string;
  surface?: 'white' | 'subtle' | 'navy';
  class?: string;
}
const { id, surface = 'white', class: className } = Astro.props;
---

<section id={id} class:list={['section', className]} data-surface={surface}>
  <div class="container" data-reveal>
    <slot />
  </div>
</section>

<style>
  .section { padding-block: clamp(var(--space-8), 8vw, var(--space-10)); }
  .section[data-surface='white'] { background: var(--color-bg); }
  .section[data-surface='subtle'] { background: var(--color-bg-subtle); }
  .section[data-surface='navy'] { background: var(--ecoteq-navy); color: var(--color-text-inverse); }
  /* Dark mode — modern B2B rhythm, not light-mode zebra striping. The bright brand
     navy reads as a glaring blue lump on near-black, so the "statement" section
     becomes ONE deliberate deep anchor (DS deep-feature band) that rhymes with the
     dark rail/footer frame. The subtle step returns to the calm, neutral DS value.
     Both stay below the card surface (#1f262c) so cards keep lifting everywhere. */
  :global(html[data-mode='dark']) .section[data-surface='navy'] { background: var(--color-feature-deep); color: var(--color-text); }
  :global(html[data-mode='dark']) .section[data-surface='subtle'] { background: var(--color-bg-subtle); }
  .container { max-width: var(--container-max); margin-inline: auto; padding-inline: clamp(16px, 4vw, 40px); }
</style>
