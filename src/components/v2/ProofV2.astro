    badge: { type: 'logo', src: '/referenciak/logok/hilti.svg', alt: 'Hilti' },
    system: 'Daráló a márkavédelmi okból megsemmisítendő termékekhez. A nagyméretű gépházakat és koffereket is egyben befogadja; egyedi adagológarat előzi meg a kemény műanyag kipattogását, a darálék átlátszó oldalfalú kocsiba hull — a folyamat végig követhető.',
    highlight: 'A zárt darálás maradéktalanul megsemmisíti a terméket.',
  },
  {
    category: 'Ipari darálás és tömörítés',
    org: 'AWF Kft., Sárvár',
    media: { type: 'photo', src: '/referenciak/awf-640.webp', srcset: '/referenciak/awf-640.webp 640w, /referenciak/awf-1280.webp 1280w', alt: 'Négytengelyes daráló késtengelyei hidraulikus leszorítóval' },
    badge: { type: 'logo', src: '/referenciak/logok/awf.png', alt: 'AWF Kft.', scale: 0.9 },
    system: 'Merev, üvegszálas autókárpit-gyártási hulladék darálása és tömörítése. A könnyű, terjedelmes anyaghoz négytengelyes darálót terveztünk hidraulikus leszorítóval; a darálékot széles szállítószalag viszi a tömörítő konténerbe.',
    highlight: 'A merev hulladék korábban alig volt tömöríthető. Darálás után a konténeres szállítás gyakorisága és költsége körülbelül az ötödére csökkent.',
  },
