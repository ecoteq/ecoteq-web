# Resend (transactional email: contact-form notification + confirmation)
RESEND_API_KEY=

# Lead e-mail beállítások (a vakuumszarito projekt konvenciója — ezt használjuk).
# Fogadó cím (ide érkeznek a megkeresések):
LEAD_NOTIFY_EMAIL=sales@ecoteq.hu
# Küldő — a domainnek HITELESÍTVE kell lennie a Resendben (send.ecoteq.hu):
LEAD_FROM_NAME=ECOTEQ
LEAD_FROM_EMAIL=noreply@send.ecoteq.hu

# Régi nevek (fallback, ha a LEAD_* nincs beállítva):
# CONTACT_TO_EMAIL=
# CONTACT_FROM_EMAIL=
