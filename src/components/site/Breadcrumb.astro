---
/**
 * Site-wide breadcrumb — ONE source of truth for breadcrumb look + spacing.
 * Own band below the hero (var(--color-bg)), UPPERCASE labels, bold green pipe
 * separators, muted/adaptive colors. Also emits BreadcrumbList JSON-LD.
 * Use on every page that needs a breadcrumb so the appearance never drifts.
 */
import Schema from '../seo/Schema.astro';

interface Item { label: string; href?: string; }
interface Props { items: Item[]; }
const { items } = Astro.props;
---

{items && items.length > 0 && (
  <>
    <div class="crumb-bar">
      <nav class="crumb" aria-label="Útvonal">
        {items.map((c, i) => (
          <>
            {c.href
              ? <a href={c.href}>{c.label}</a>
              : <span class="here" aria-current="page">{c.label}</span>}
            {i < items.length - 1 && <span class="sep" aria-hidden="true">|</span>}
          </>
        ))}
      </nav>
    </div>
    <Schema breadcrumbs={items.map((c) => ({ name: c.label, href: c.href }))} />
  </>
)}

<style>
  /* Kompakt breadcrumb-sáv: egységes, modáns térköz a hero és a section között.
     A negatív alsó margó felhúzza a következő section-t, így nincs dupla szakadék. */
  .crumb-bar { background: var(--color-bg); margin-bottom: calc(-1 * clamp(var(--space-5), 4.5vw, var(--space-7))); }
  .crumb-bar .crumb {
    max-width: var(--container-max);
    margin-inline: auto;
    padding: clamp(var(--space-5), 3vw, var(--space-6)) clamp(16px, 4vw, 40px) var(--space-3);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    font-size: var(--fs-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .crumb-bar .crumb a { color: var(--color-text-secondary); text-decoration: none; }
  .crumb-bar .crumb a:hover { color: var(--color-accent); }
  .crumb-bar .crumb .here { color: var(--color-text); }
  .crumb-bar .crumb .sep { color: var(--color-accent); font-weight: var(--fw-bold); }
</style>
