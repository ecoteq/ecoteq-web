---
/** Generic surface card — soft navy-tinted shadow, hairline border, hover lift. */
interface Props {
  interactive?: boolean;
  padding?: number | string;
  href?: string;
  class?: string;
  [key: string]: unknown;
}

const { interactive = false, padding = 24, href, class: className, ...rest } = Astro.props;
const Tag = href ? 'a' : 'div';
const pad = typeof padding === 'number' ? `${padding}px` : padding;
---

<Tag
  class:list={['card', className]}
  data-interactive={interactive || href ? '' : undefined}
  href={href}
  style={`--card-padding:${pad}`}
  {...rest}
>
  <slot />
</Tag>

<style>
  .card {
    display: block;
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: var(--card-padding, 24px);
    color: inherit;
    text-decoration: none;
  }
  .card[data-interactive] {
    cursor: pointer;
    transition:
      box-shadow var(--dur-base) var(--ease-standard),
      border-color var(--dur-base) var(--ease-standard),
      transform var(--dur-base) var(--ease-standard);
  }
  .card[data-interactive]:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-strong);
    transform: translateY(-2px);
  }
  @media (prefers-reduced-motion: reduce) {
    .card[data-interactive] { transition: none; }
    .card[data-interactive]:hover { transform: none; }
  }
</style>
