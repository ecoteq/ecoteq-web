---
import Tag from './Tag.astro';

/**
 * Product card — photo with navy wash + category tag, title, short copy,
 * and a green "read more" affordance. Composes Tag.
 */
interface Props {
  image?: string;
  imageAlt?: string;
  category?: string;
  title: string;
  description?: string;
  cta?: string;
  href?: string;
  class?: string;
  [key: string]: unknown;
}

const {
  image,
  imageAlt = '',
  category,
  title,
  description,
  cta = 'Részletek',
  href,
  class: className,
  ...rest
} = Astro.props;

const Tag2 = href ? 'a' : 'article';
---

<Tag2 class:list={['pcard', className]} href={href} {...rest}>
  <div class="media">
    {image ? (
      <img class="img" src={image} alt={imageAlt} loading="lazy" decoding="async" />
    ) : (
      <div class="img placeholder" aria-hidden="true"></div>
    )}
    <div class="wash" aria-hidden="true"></div>
    {category && <div class="cat"><Tag>{category}</Tag></div>}
  </div>
  <div class="body">
    <h3 class="title">{title}</h3>
    {description && <p class="desc">{description}</p>}
    <span class="cta">{cta} <span aria-hidden="true">→</span></span>
  </div>
</Tag2>

<style>
  .pcard {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition:
      box-shadow var(--dur-base) var(--ease-standard),
      border-color var(--dur-base) var(--ease-standard),
      transform var(--dur-base) var(--ease-standard);
  }
  .pcard:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-border-strong);
    transform: translateY(-3px);
  }
  .pcard:hover .img { transform: scale(1.05); }
  .pcard:hover .cta { gap: 12px; }

  .media { position: relative; height: 180px; overflow: hidden; }
  .img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }
  .placeholder {
    background: repeating-linear-gradient(115deg, #3a4a5a 0 22px, #33424f 22px 44px);
  }
  .wash { position: absolute; inset: 0; background: var(--overlay-navy); }
  .cat { position: absolute; left: 16px; bottom: 16px; }

  .body { padding: 22px; display: flex; flex-direction: column; gap: 8px; }
  .title { margin: 0; font-size: var(--fs-h4); font-weight: var(--fw-bold); color: var(--color-text); }
  .desc { margin: 0; font-size: var(--fs-sm); color: var(--color-text-secondary); line-height: var(--lh-snug); }
  .cta {
    margin-top: 6px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-accent);
    font-weight: var(--fw-bold);
    font-size: var(--fs-sm);
    transition: gap var(--dur-base) var(--ease-standard);
  }

  @media (prefers-reduced-motion: reduce) {
    .pcard, .img, .cta { transition: none; }
    .pcard:hover { transform: none; }
    .pcard:hover .img { transform: none; }
  }
</style>
