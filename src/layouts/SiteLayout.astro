---
/* Canonical site layout. Delegates to the reconciled V2 chrome (SiteHeaderV2 +
   SiteFooterV2) so every page — including legal/utility pages — shares one header,
   footer and CTA system. Same props as before. */
import SiteLayoutV2 from '../components/v2/SiteLayoutV2.astro';

interface Props {
  title: string;
  description?: string;
  brand?: string;
  solidHeader?: boolean;
  headerCta?: { label: string; href: string };
}
const { title, description, brand, solidHeader = false, headerCta } = Astro.props;
---

<SiteLayoutV2
  title={title}
  description={description}
  brand={brand}
  solidHeader={solidHeader}
  headerCta={headerCta}
>
  <slot />
</SiteLayoutV2>
