---
import SiteLayout from '../../layouts/SiteLayout.astro';
import Section from '../../components/layout/Section.astro';
import SectionHeading from '../../components/brand/SectionHeading.astro';
import Button from '../../components/core/Button.astro';
import Icon from '../../components/Icon.astro';
import Overline from '../../components/brand/Overline.astro';
import { gatewaySlugs, getGateway } from '../../lib/technologies';

export function getStaticPaths() {
  return gatewaySlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const t = getGateway(slug!);
if (!t) return Astro.redirect('/404');

const QUOTE = { label: 'Technológiai irányt kérek', href: '/#ajanlatkeres' };
const FORM_CTA = { label: 'Elküldöm a projekt adatait', href: '/#ajanlatkeres' };
---

<SiteLayout title={t.metaTitle} description={t.metaDescription}>
  <!-- HERO -->
  <section class="hero">
    {t.hero.image && (
      <div class="media">
        <img src={t.hero.image} alt={t.hero.imageAlt ?? t.name} fetchpriority="high" decoding="async" />
        <div class="wash" aria-hidden="true"></div>
      </div>
    )}
    <div class="hero-inner">
      <nav class="crumb" aria-label="Útvonal">
        <a href="/">Főoldal</a><span>/</span><a href="/#technologiak">Technológiák</a><span>/</span><span class="here">{t.name}</span>
      </nav>
      <Overline class="eyebrow">{t.hero.eyebrow}</Overline>
      <h1>{t.hero.h1}</h1>
      <p class="lead">{t.hero.lead}</p>
      <div class="ctas">
        <Button href={QUOTE.href}>{QUOTE.label}</Button>
        {t.hero.secondaryCta && <Button variant="outline-light" href={t.hero.secondaryCta.href}>{t.hero.secondaryCta.label}</Button>}
      </div>
      <p class="microcopy">{t.hero.microcopy}</p>
      <ul class="pills">{t.hero.trustPills.map((p) => <li>{p}</li>)}</ul>
    </div>
  </section>

  <!-- 2. MIKOR JÓ IRÁNY -->
  <Section surface="white">
    <SectionHeading overline="Mikor jó irány" title={t.fit.h2} lead={t.fit.intro} />
    <div class="grid cards3">
      {t.fit.items.map((i) => (
        <article class="card">
          <span class="rule" aria-hidden="true"></span>
          <h3>{i.title}</h3>
          <p>{i.text}</p>
        </article>
      ))}
    </div>
  </Section>

  <!-- 3. PROBLÉMA -->
  <Section surface="subtle">
    <SectionHeading overline="Üzemi probléma" title={t.problems.h2} lead={t.problems.intro} />
    <div class="grid cards2">
      {t.problems.cards.map((c) => (
        <article class="pcard">
          <h3>{c.problem}</h3>
          <p class="lbl">Miért gond?</p><p>{c.why}</p>
          <p class="lbl">Technológiai válasz</p><p>{c.answer}</p>
        </article>
      ))}
    </div>
  </Section>

  <!-- 4. ANYAGOK -->
  <Section surface="white">
    <SectionHeading overline="Anyagok és alkalmazások" title={t.materials.h2} lead={t.materials.intro} />
    <div class="matrix">
      <div><h3>Anyagok</h3><ul>{t.materials.materials.map((m) => <li>{m}</li>)}</ul></div>
      <div><h3>Iparágak</h3><ul>{t.materials.industries.map((m) => <li>{m}</li>)}</ul></div>
      <div><h3>Tipikus célok</h3><ul>{t.materials.goals.map((m) => <li>{m}</li>)}</ul></div>
    </div>
  </Section>

  <!-- 5. RENDSZERFELÉPÍTÉS -->
  <Section surface="subtle">
    <SectionHeading overline="Rendszerfelépítés" title={t.process.h2} lead={t.process.intro} />
    <ol class="steps">
      {t.process.steps.map((s, i) => (
        <li><span class="num">{String(i + 1).padStart(2, '0')}</span><div><h3>{s.title}</h3><p>{s.text}</p></div></li>
      ))}
    </ol>
  </Section>

  <!-- 6. DÖNTÉSI TÉNYEZŐK -->
  <Section surface="white">
    <SectionHeading overline="Döntés előtt" title={t.decisionFactors.h2} lead={t.decisionFactors.intro} />
    <div class="grid cards2 tight">
      {t.decisionFactors.factors.map((f) => (
        <div class="factor"><span class="ic"><Icon name="check" size={16} /></span><div><h3>{f.title}</h3><p>{f.text}</p></div></div>
      ))}
    </div>
  </Section>

  <!-- 7. ECOTEQ SZEREPE (navy) -->
  <Section surface="navy">
    <SectionHeading tone="dark" overline="ECOTEQ szerepe" title={t.role.h2} />
    <div class="role">
      <div class="role-body">{t.role.body.map((p) => <p>{p}</p>)}</div>
      <div class="role-points">
        {t.role.points.map((p) => (
          <div class="rp"><span class="rule" aria-hidden="true"></span><h3>{p.title}</h3><p>{p.text}</p></div>
        ))}
      </div>
    </div>
    <Button href={QUOTE.href}>{QUOTE.label}</Button>
  </Section>

  <!-- 8. KAPCSOLÓDÓ TECHNOLÓGIÁK -->
  <Section surface="subtle">
    <SectionHeading overline="Kapcsolódó technológiák" title={t.related.h2} lead={t.related.intro} />
    <div class="grid cards2">
      {t.related.links.map((l) => (
        <a class="rel" href={l.href}>
          <h3>{l.label} <Icon name="arrow-right" size={16} /></h3>
          {l.description && <p>{l.description}</p>}
        </a>
      ))}
    </div>
    {t.related.spoke && (
      <a class="spoke" href={t.related.spoke.href}>
        <div>
          <p class="lbl">Részletes szakmai oldal</p>
          <p class="spoke-desc">{t.related.spoke.description}</p>
        </div>
        <span class="spoke-cta">{t.related.spoke.label} <Icon name="arrow-up-right" size={18} /></span>
      </a>
    )}
  </Section>

  <!-- 9. ELŐMINŐSÍTÉS -->
  <Section id="ajanlatkeres-info" surface="white">
    <div class="prequal">
      <SectionHeading overline="Előminősítés" title={t.preQual.h2} lead={t.preQual.body} />
      <div class="prequal-data">
        <p class="lbl">Hasznos, ha tudjuk:</p>
        <ul>{t.preQual.fields.map((f) => <li><Icon name="check" size={15} />{f}</li>)}</ul>
        <Button href={FORM_CTA.href}>{FORM_CTA.label}</Button>
        <p class="micro">A beérkező megkereséseket munkanapokon előszűrjük, és jellemzően 24 órán belül visszajelzünk a következő lépésről.</p>
      </div>
    </div>
  </Section>

  <!-- 10. GYIK -->
  <Section surface="subtle">
    <SectionHeading overline="GYIK" title={t.faq.h2} />
    <div class="faq">
      {t.faq.items.map((f) => (
        <details>
          <summary>{f.q}<Icon name="chevron-down" size={20} /></summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </Section>

  <!-- 11. ZÁRÓ CTA -->
  <section class="closing">
    <div class="closing-inner">
      <h2>{t.finalCta.h2}</h2>
      {t.finalCta.body.map((p) => <p>{p}</p>)}
      <div class="ctas">
        <Button href={QUOTE.href}>{QUOTE.label}</Button>
        {t.finalCta.secondaryCta && <Button variant="ghost" href={t.finalCta.secondaryCta.href}>{t.finalCta.secondaryCta.label}</Button>}
      </div>
      <p class="micro">Az első lépés nem kötelezettségvállalás, hanem szakmai előminősítés.</p>
    </div>
  </section>
</SiteLayout>

<style>
  /* HERO */
  .hero { position: relative; margin-top: calc(-1 * var(--header-h)); min-height: min(76svh, 680px); display: flex; align-items: center; overflow: hidden; background: var(--ecoteq-navy); }
  .media { position: absolute; inset: 0; z-index: 0; }
  .media img { width: 100%; height: 100%; object-fit: cover; }
  .wash { position: absolute; inset: 0; background: linear-gradient(90deg, rgba(28,52,73,0.95) 0%, rgba(28,52,73,0.72) 46%, rgba(28,52,73,0.28) 100%), linear-gradient(0deg, rgba(15,32,48,0.6) 0%, rgba(15,32,48,0) 50%); }
  .hero-inner { position: relative; z-index: 1; width: 100%; max-width: var(--container-max); margin-inline: auto; padding: calc(var(--header-h) + var(--space-6)) clamp(16px, 4vw, 40px) var(--space-7); }
  .crumb { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; font-size: var(--fs-sm); color: rgba(255,255,255,0.7); margin-bottom: var(--space-5); }
  .crumb a { color: rgba(255,255,255,0.7); text-decoration: none; }
  .crumb a:hover { color: var(--ecoteq-green); }
  .crumb .here { color: var(--ecoteq-white); }
  .eyebrow { color: var(--ecoteq-green); margin-bottom: var(--space-3); }
  h1 { color: var(--ecoteq-white); font-size: clamp(1.9rem, 1.2rem + 2.6vw, 3.25rem); line-height: var(--lh-tight); letter-spacing: var(--ls-display); max-width: 20ch; margin: 0 0 var(--space-4); }
  .lead { color: rgba(255,255,255,0.86); font-size: var(--fs-lg); line-height: var(--lh-body); max-width: 62ch; margin: 0 0 var(--space-5); }
  .ctas { display: flex; flex-wrap: wrap; gap: var(--space-4); }
  .microcopy { color: rgba(255,255,255,0.66); font-size: var(--fs-sm); max-width: 56ch; margin: var(--space-4) 0 var(--space-5); }
  .pills { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 8px; }
  .pills li { font-size: var(--fs-xs); font-weight: var(--fw-semibold); color: #fff; padding: 6px 13px; border-radius: var(--radius-pill); background: rgba(255,255,255,0.08); box-shadow: inset 0 0 0 1px rgba(255,255,255,0.28); }

  /* Shared grids */
  .grid { margin-top: var(--space-7); display: grid; gap: var(--space-4); }
  .cards3 { grid-template-columns: 1fr; }
  .cards2 { grid-template-columns: 1fr; }
  @media (min-width: 720px) { .cards3 { grid-template-columns: repeat(3, 1fr); } .cards2 { grid-template-columns: 1fr 1fr; } }

  .card { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-5); }
  .card .rule { display: block; width: 36px; height: 4px; border-radius: var(--radius-pill); background: var(--color-accent); margin-bottom: var(--space-3); }
  .card h3 { margin: 0 0 6px; font-size: var(--fs-h4); font-weight: var(--fw-bold); color: var(--color-text); }
  .card p { margin: 0; font-size: var(--fs-sm); color: var(--color-text-secondary); line-height: var(--lh-snug); }

  .pcard { background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-6); }
  .pcard h3 { margin: 0 0 var(--space-3); font-size: var(--fs-h4); font-weight: var(--fw-bold); color: var(--color-text); }
  .pcard .lbl { margin: var(--space-3) 0 2px; font-size: var(--fs-xs); font-weight: var(--fw-bold); letter-spacing: var(--ls-overline); text-transform: uppercase; color: var(--color-accent-text); }
  .pcard p { margin: 0; font-size: var(--fs-sm); color: var(--color-text-secondary); line-height: var(--lh-snug); }

  /* Materials matrix */
  .matrix { margin-top: var(--space-7); display: grid; gap: var(--space-5); grid-template-columns: 1fr; }
  @media (min-width: 720px) { .matrix { grid-template-columns: repeat(3, 1fr); } }
  .matrix h3 { margin: 0 0 var(--space-3); padding-bottom: var(--space-3); border-bottom: 1px solid var(--color-border); font-size: var(--fs-xs); font-weight: var(--fw-bold); letter-spacing: var(--ls-overline); text-transform: uppercase; color: var(--color-accent-text); }
  .matrix ul { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .matrix li { font-size: var(--fs-sm); color: var(--color-text-secondary); }

  /* Steps */
  .steps { margin-top: var(--space-7); padding: 0; list-style: none; display: grid; gap: var(--space-5); grid-template-columns: 1fr; }
  @media (min-width: 760px) { .steps { grid-template-columns: 1fr 1fr; gap: var(--space-6) var(--space-7); } }
  .steps li { display: flex; gap: var(--space-4); align-items: flex-start; }
  .num { flex: none; font-family: var(--font-display); font-size: var(--fs-h3); font-weight: var(--fw-extrabold); color: var(--color-accent); line-height: 1; letter-spacing: var(--ls-display); }
  .steps h3 { margin: 0 0 4px; font-size: var(--fs-h4); font-weight: var(--fw-bold); color: var(--color-text); }
  .steps p { margin: 0; font-size: var(--fs-sm); color: var(--color-text-secondary); line-height: var(--lh-snug); }

  /* Decision factors */
  .tight { gap: var(--space-5) var(--space-6); }
  .factor { display: flex; gap: var(--space-3); align-items: flex-start; }
  .factor .ic { flex: none; width: 30px; height: 30px; border-radius: var(--radius-pill); background: var(--color-accent-tint); color: var(--green-700); display: grid; place-items: center; }
  .factor h3 { margin: 0 0 3px; font-size: var(--fs-h4); font-weight: var(--fw-bold); color: var(--color-text); }
  .factor p { margin: 0; font-size: var(--fs-sm); color: var(--color-text-secondary); line-height: var(--lh-snug); }

  /* Role (navy) */
  .role { margin: var(--space-7) 0; display: grid; gap: var(--space-7); grid-template-columns: 1fr; }
  @media (min-width: 880px) { .role { grid-template-columns: 0.9fr 1.1fr; gap: var(--space-8); } }
  .role-body p { color: rgba(255,255,255,0.82); line-height: var(--lh-body); margin: 0 0 var(--space-4); }
  .role-points { display: grid; gap: var(--space-5); grid-template-columns: 1fr; }
  @media (min-width: 560px) { .role-points { grid-template-columns: 1fr 1fr; } }
  .rp .rule { display: block; width: 32px; height: 4px; border-radius: var(--radius-pill); background: var(--color-accent); margin-bottom: 10px; }
  .rp h3 { margin: 0 0 4px; font-size: var(--fs-h4); font-weight: var(--fw-bold); color: #fff; }
  .rp p { margin: 0; font-size: var(--fs-sm); color: rgba(255,255,255,0.72); line-height: var(--lh-snug); }

  /* Related */
  .rel { display: flex; flex-direction: column; gap: 6px; background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: var(--space-5); text-decoration: none; color: inherit; transition: box-shadow var(--dur-base) var(--ease-standard), transform var(--dur-base) var(--ease-standard); }
  .rel:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .rel h3 { margin: 0; display: inline-flex; align-items: center; gap: 8px; font-size: var(--fs-h4); font-weight: var(--fw-bold); color: var(--color-accent-text); }
  .rel p { margin: 0; font-size: var(--fs-sm); color: var(--color-text-secondary); line-height: var(--lh-snug); }
  .spoke { margin-top: var(--space-5); display: flex; flex-wrap: wrap; gap: var(--space-4); justify-content: space-between; align-items: center; background: var(--ecoteq-navy); border-radius: var(--radius-lg); padding: var(--space-6); text-decoration: none; }
  .spoke .lbl { margin: 0 0 4px; font-size: var(--fs-xs); font-weight: var(--fw-bold); letter-spacing: var(--ls-overline); text-transform: uppercase; color: var(--ecoteq-green); }
  .spoke-desc { margin: 0; color: rgba(255,255,255,0.82); font-size: var(--fs-sm); max-width: 60ch; }
  .spoke-cta { display: inline-flex; align-items: center; gap: 8px; color: #fff; font-weight: var(--fw-bold); font-size: var(--fs-sm); }

  /* PreQual */
  .prequal { display: grid; gap: var(--space-6); grid-template-columns: 1fr; }
  @media (min-width: 880px) { .prequal { grid-template-columns: 1fr 1fr; align-items: start; gap: var(--space-8); } }
  .prequal-data .lbl { margin: 0 0 var(--space-3); font-size: var(--fs-sm); font-weight: var(--fw-semibold); color: var(--ecoteq-navy); }
  .prequal-data ul { margin: 0 0 var(--space-5); padding: 0; list-style: none; display: grid; gap: 10px; }
  .prequal-data li { display: flex; align-items: flex-start; gap: 10px; font-size: var(--fs-sm); color: var(--color-text-secondary); }
  .prequal-data li :global(.icon) { color: var(--color-accent); flex: none; margin-top: 3px; }
  .micro { margin: var(--space-3) 0 0; font-size: var(--fs-sm); color: var(--color-text-muted); max-width: 60ch; }

  /* FAQ */
  .faq { margin-top: var(--space-6); display: flex; flex-direction: column; gap: 0; max-width: 820px; }
  details { border-bottom: 1px solid var(--color-border); }
  summary { display: flex; align-items: center; justify-content: space-between; gap: var(--space-4); cursor: pointer; list-style: none; padding: var(--space-5) 0; font-size: var(--fs-lg); font-weight: var(--fw-semibold); color: var(--color-text); }
  summary::-webkit-details-marker { display: none; }
  summary :global(.icon) { transition: transform var(--dur-base) var(--ease-standard); color: var(--color-accent); flex: none; }
  details[open] summary :global(.icon) { transform: rotate(180deg); }
  details p { margin: 0; padding: 0 0 var(--space-5); font-size: var(--fs-body); color: var(--color-text-secondary); line-height: var(--lh-body); max-width: 70ch; }

  /* Closing */
  .closing { background: var(--color-accent-tint); padding-block: clamp(var(--space-8), 8vw, var(--space-10)); }
  .closing-inner { max-width: 760px; margin-inline: auto; padding-inline: clamp(16px, 4vw, 40px); text-align: center; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); }
  .closing h2 { margin: 0; font-family: var(--font-display); font-weight: var(--fw-extrabold); font-size: var(--fs-h2); line-height: var(--lh-heading); letter-spacing: var(--ls-heading); color: var(--color-text); max-width: 22ch; }
  .closing p { margin: 0; font-size: var(--fs-lg); line-height: var(--lh-body); color: var(--color-text-secondary); }
  .closing .ctas { justify-content: center; margin-top: var(--space-3); }

  @media (prefers-reduced-motion: reduce) {
    .rel, summary :global(.icon) { transition: none; }
    .rel:hover { transform: none; }
  }
</style>
