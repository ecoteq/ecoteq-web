---
import Section from '../layout/Section.astro';
import SectionHeading from '../brand/SectionHeading.astro';
import Button from '../core/Button.astro';
import { CTA } from '../../lib/site';

const partners = [
  { name: 'ISVE', text: 'Vákuumszárítási, vákuumimpregnálási és faipari speciális technológiák területén.' },
  { name: 'Prodeco', text: 'Hidraulikus brikettálási technológiák faipari és biomassza alapanyagokhoz.' },
  { name: 'CF Nielsen', text: 'Mechanikus brikettálási rendszerek nagyobb ipari kapacitású feladatokhoz.' },
  { name: 'AL-KO Extraction Technology', text: 'Elszívástechnikai és levegőtechnikai rendszerek ipari és faipari környezetben.' },
];
---

<Section surface="subtle">
  <SectionHeading
    overline="Gyártói háttér"
    title="Elismert európai gyártók, magyar szakértői támogatással."
    lead="Az ECOTEQ több technológiai területen dolgozik európai gyártópartnerekkel, mert különböző anyagokra és üzemhelyzetekre nem ugyanaz a gép vagy gyártó adja a legjobb választ. A pontos ajánlás mindig az anyag, a kapacitás, a céltermék és az üzemi környezet alapján történik."
  />

  <div class="grid">
    {partners.map((p) => (
      <article class="partner">
        <h3>{p.name}</h3>
        <p>{p.text}</p>
      </article>
    ))}
    <article class="partner more">
      <h3>További technológiai partnerek</h3>
      <p>A feladattól függően más európai gyártói háttér vagy egyedi rendszerintegráció is szóba jöhet.</p>
    </article>
  </div>

  <div class="cta-wrap">
    <Button href={CTA.primary.href}>Technológiát választok feladathoz, nem márkanévhez</Button>
  </div>
</Section>

<style>
  .grid {
    margin-top: var(--space-7);
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1000px) { .grid { grid-template-columns: repeat(3, 1fr); } }

  .partner {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
  }
  .partner h3 {
    margin: 0 0 var(--space-2);
    font-family: var(--font-display);
    font-size: var(--fs-h4);
    font-weight: var(--fw-extrabold);
    letter-spacing: var(--ls-heading);
    color: var(--color-text);
  }
  .partner p { margin: 0; font-size: var(--fs-sm); color: var(--color-text-secondary); line-height: var(--lh-snug); }
  .partner.more { background: transparent; border-style: dashed; }

  .cta-wrap { margin-top: var(--space-7); }
</style>
